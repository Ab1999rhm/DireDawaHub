<!-- Water Distribution Section -->
<div id="water-section" class="dashboard-section">
    <div class="section-header">
        <h3 class="section-title">
            <span class="section-icon water">💧</span>
            @SharedLocalizer["WaterHeader"]
        </h3>
        <a href="#" class="view-all-link">
            @SharedLocalizer["ViewAll"] →
        </a>
    </div>
    <div class="row g-4" id="waterFeed">
        @if (Model.WaterSchedules.Any())
        {
            @foreach (var water in Model.WaterSchedules)
            {
                <div class="col-md-6 col-lg-4 filterable-item">
                    <div class="dd-card water-card h-100">
                        <div class="dd-card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="location-name">@water.Location</span>
                                @if (water.Status == "Active")
                                {
                                    <span class="status-badge active">@SharedLocalizer["StatusFlowing"]</span>
                                }
                                else if (water.Status == "Delayed")
                                {
                                    <span class="status-badge delayed">@SharedLocalizer["StatusDelayed"]</span>
                                }
                                else
                                {
                                    <span class="status-badge scheduled">@SharedLocalizer["StatusScheduled"]</span>
                                }
                            </div>
                            <div class="schedule-time">
                                <span>🕐</span>
                                <span>@water.StartTime.ToString("MMM dd, h:mm tt") - @water.EndTime.ToString("h:mm tt")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(water.Notes))
                            {
                                <div class="schedule-note">
                                    <strong>@SharedLocalizer["ServiceNotice"]:</strong> @water.Notes
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="dd-card">
                    <div class="empty-state">
                        <div class="empty-state-icon">💧</div>
                        <p>@SharedLocalizer["NoWaterSchedules"]</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Healthcare Facilities Section -->
