@model DireDawaHub.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Hub Authentication";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, rgba(30, 64, 175, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%),
                    url('/images/smart_banner.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        color: #0f172a;
        overflow-x: hidden;
        animation: panBackground 25s infinite alternate ease-in-out;
    }

    @@keyframes panBackground {
        0% { background-size: 100%; background-position: center center; }
        100% { background-size: 115%; background-position: right bottom; }
    }

    /* Floating glowing orbs */
    body::before, body::after {
        content: '';
        position: fixed;
        width: 50vw;
        height: 50vw;
        border-radius: 50%;
        filter: blur(120px);
        z-index: -1;
        opacity: 0.6;
        animation: floatOrb 20s infinite ease-in-out alternate;
        pointer-events: none;
    }
    body::before {
        background: rgba(59, 130, 246, 0.6);
        top: -10vh; left: -10vw;
    }
    body::after {
        background: rgba(16, 185, 129, 0.4);
        bottom: -10vh; right: -10vw;
        animation-delay: -10s;
        animation-duration: 25s;
    }

    @@keyframes floatOrb {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(10vw, 15vh) scale(1.1); }
        100% { transform: translate(-10vw, 10vh) scale(0.9); }
    }

    .auth-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
        position: relative;
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px) saturate(180%);
        -webkit-backdrop-filter: blur(12px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
        width: 100%;
        max-width: 480px;
        overflow: hidden;
        transform: translateY(0);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
        animation: scaleIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .auth-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3);
    }

    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.95) translateY(40px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .auth-banner {
        width: 100%;
        height: 140px;
        object-fit: cover;
        border-bottom: 1px solid #e2e8f0;
    }

    .auth-body {
        padding: 2.5rem;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-icon {
        font-size: 3rem;
        color: #3b82f6;
        margin-bottom: 0.5rem;
        display: inline-block;
        filter: drop-shadow(0 2px 4px rgba(59, 130, 246, 0.3));
        animation: floatIcon 4s ease-in-out infinite;
    }

    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0px) scale(1); filter: drop-shadow(0 2px 4px rgba(59, 130, 246, 0.3)); }
        50% { transform: translateY(-10px) scale(1.05); filter: drop-shadow(0 8px 12px rgba(59, 130, 246, 0.5)); }
    }

    .auth-header h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.5rem 0;
        letter-spacing: -0.025em;
    }

    .auth-header p {
        color: #475569;
        font-size: 0.95rem;
        margin: 0;
    }

    .form-label {
        color: #1e293b;
        font-weight: 500;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .form-control, .input-group-text, .input-group {
        transition: all 0.3s ease;
    }

    .input-group:focus-within {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.05);
    }

    .form-control {
        background: #ffffff;
        border: 1px solid #cbd5e1;
        color: #0f172a;
        border-radius: 10px;
        padding: 0.75rem 1rem;
    }

    .form-control:focus {
        background: #ffffff;
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        color: #0f172a;
        outline: none;
    }

    .form-control::placeholder {
        color: #94a3b8;
    }

    .input-group-text {
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        border-right: none;
        color: #64748b;
    }

    .form-control.with-icon {
        border-left: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        background-size: 200% auto;
        border: none;
        padding: 0.875rem;
        border-radius: 10px;
        font-weight: 600;
        letter-spacing: 0.025em;
        width: 100%;
        transition: all 0.4s ease;
        margin-top: 1rem;
        color: #ffffff;
        box-shadow: 0 4px 14px 0 rgba(37, 99, 235, 0.2);
    }

    .btn-primary:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 8px 25px rgba(37, 99, 235, 0.4);
        background-position: right center;
    }

    .auth-footer {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.95rem;
        color: #475569;
    }

    .auth-footer a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
    }

    .auth-footer a:hover {
        color: #1e40af;
        text-decoration: underline;
    }

    .form-check-label {
        color: #475569;
        font-size: 0.9rem;
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <img src="/images/banner.png" alt="Login Banner" class="auth-banner" />
        <div class="auth-body">
            <div class="auth-header">
                <i class="bi bi-person-circle auth-icon"></i>
                <h2>Dire Dawa Hub</h2>
                <p>Sign in to your account</p>
            </div>

            <form asp-controller="Account" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control with-icon" placeholder="admin@diredawa.gov.et" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" id="password" class="form-control with-icon border-end-0" placeholder="••••••••" />
                        <span class="input-group-text bg-transparent border-start-0" style="cursor: pointer; border-left: none; background: #ffffff;" onclick="togglePassword()">
                            <i class="bi bi-eye-slash" id="togglePasswordIcon" style="color: #64748b;"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4 form-check">
                    <input class="form-check-input" asp-for="RememberMe" />
                    <label class="form-check-label" asp-for="RememberMe">Keep me signed in</label>
                </div>

                <button type="submit" class="btn btn-primary text-white">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>

                <div class="auth-footer">
                    Don't have an account? <a asp-action="Register">Register as a Contributor</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function togglePassword() {
        const password = document.getElementById("password");
        const icon = document.getElementById("togglePasswordIcon");
        if (password.type === "password") {
            password.type = "text";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
            icon.style.color = "#3b82f6";
        } else {
            password.type = "password";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
            icon.style.color = "#64748b";
        }
    }
</script>