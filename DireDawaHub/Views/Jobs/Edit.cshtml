@model DireDawaHub.Models.JobPosting
@{
    ViewData["Title"] = "Edit Job Posting";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4">💼 Edit Job/Training Posting</h2>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PostedDate" />
                        <input type="hidden" asp-for="ContributorId" />
                        <input type="hidden" asp-for="IsApproved" />
                        
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Title</label>
                            <input asp-for="Title" class="form-control rounded-3" required />
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <label asp-for="Company" class="form-label fw-bold">Company / Institution</label>
                                <input asp-for="Company" class="form-control rounded-3" required />
                            </div>
                            <div class="col-6">
                                <label asp-for="Location" class="form-label fw-bold">Location</label>
                                <input asp-for="Location" class="form-control rounded-3" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="5" required></textarea>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsTrainingOpportunity" class="form-check-input" type="checkbox">
                                <label asp-for="IsTrainingOpportunity" class="form-check-label fw-bold">This is a Training/Apprenticeship Opportunity</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-3 fw-bold">SAVE CHANGES</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill py-3">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
