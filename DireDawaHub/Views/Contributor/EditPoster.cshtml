@model DireDawaHub.Models.CommunityPoster
@{
    ViewData["Title"] = "Edit Community Poster";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="fw-bold mb-0">✏️ Edit Poster</h2>
                        <a asp-action="MyPosters" class="btn btn-light rounded-pill px-3">Cancel</a>
                    </div>
                    <p class="text-muted mb-5">Update your event announcement or blog post.</p>

                    <form asp-action="EditPoster" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Poster Title</label>
                            <input type="text" name="title" value="@Model.Title" class="form-control form-control-lg rounded-3" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Short Description (Snippet)</label>
                            <input type="text" name="description" value="@Model.Description" class="form-control rounded-3" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Detailed Content (Full Blog)</label>
                            <textarea name="content" class="form-control rounded-3" rows="8">@Model.Content</textarea>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Category</label>
                                <select name="category" class="form-select rounded-3">
                                    <option value="Event" selected="@(Model.Category == "Event")">Event</option>
                                    <option value="Announcement" selected="@(Model.Category == "Announcement")">Announcement</option>
                                    <option value="Education" selected="@(Model.Category == "Education")">Education</option>
                                    <option value="Health" selected="@(Model.Category == "Health")">Health</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Location (Optional)</label>
                                <input type="text" name="location" value="@Model.Location" class="form-control rounded-3" placeholder="e.g., Taiwan Market">
                            </div>
                        </div>

                        <div class="mb-5">
                            <label class="form-label fw-bold">Change Image (Optional)</label>
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <img src="@Model.ImagePath" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">
                                <span class="small text-muted">Current Image</span>
                            </div>
                            <input type="file" name="image" class="form-control rounded-3" accept="image/*">
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold">
                                <i class="bi bi-save"></i> SAVE CHANGES
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
