@{
    ViewData["Title"] = "Admin Control Panel";
}

<div class="d-flex justify-content-between align-items-center mb-5 mt-2">
    <div>
        <h2 class="fw-bold" style="color: #111827;">🛡️ Admin Control Panel</h2>
        <p class="text-muted mb-0">System Overview and Central Application Management</p>
    </div>
    <a asp-action="ManageUsers" class="btn btn-dark fw-bold px-4 py-2 shadow-sm" style="border-radius: 8px;">👥 Manage Access & Roles</a>
</div>

<div class="row mb-5 g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-left: 5px solid #3b82f6 !important;">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold text-uppercase mb-1 small">Registered Accounts</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalUsers</h2>
                </div>
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary fs-3">
                    👥
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-left: 5px solid #10b981 !important;">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold text-uppercase mb-1 small">Water Schedules</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalWaterRecords</h2>
                </div>
                <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success fs-3">
                    💧
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-left: 5px solid #f59e0b !important;">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold text-uppercase mb-1 small">Active Job Postings</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalJobs</h2>
                </div>
                <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning fs-3">
                    💼
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
            <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">📜 Security Audit Log (Recent Actions)</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0 border-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3 border-0">Action Type</th>
                            <th class="py-3 border-0">Audit Details</th>
                            <th class="py-3 border-0">Timestamp</th>
                            <th class="pe-4 py-3 text-end border-0">Moderation</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.RecentJobs != null)
                        {
                            var jobs = (IEnumerable<DireDawaHub.Models.JobPosting>)ViewBag.RecentJobs;
                            if (jobs.Any())
                            {
                                foreach(var job in jobs)
                                {
                                    <tr>
                                        <td class="ps-4 py-3"><span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">Job Creation</span></td>
                                        <td class="py-3 fw-bold text-dark">Contributor posted: "@job.Title"</td>
                                        <td class="py-3 text-muted small">@job.PostedDate.ToString("g")</td>
                                        <td class="pe-4 py-3 text-end">
                                            <form asp-action="DeleteJob" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@job.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger px-3 shadow-sm fw-bold border-0" style="border-radius: 6px;" onclick="return confirm('Are you sure you want to permanently delete this system record?');">
                                                    <i class="bi bi-trash3"></i> Delete Record
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">No recent system activity recorded.</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
