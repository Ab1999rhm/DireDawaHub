@model DireDawaHub.ViewModels.RegisterViewModel
@using DireDawaHub.Models
@{
    ViewData["Title"] = "Register as Contributor";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, rgba(30, 64, 175, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%),
                    url('/images/smart_banner.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        color: #0f172a;
        overflow-x: hidden;
        animation: panBackground 25s infinite alternate ease-in-out;
    }

    @@keyframes panBackground {
        0% { background-size: 100%; background-position: center center; }
        100% { background-size: 115%; background-position: right bottom; }
    }

    /* Floating glowing orbs */
    body::before, body::after {
        content: '';
        position: fixed;
        width: 50vw;
        height: 50vw;
        border-radius: 50%;
        filter: blur(120px);
        z-index: -1;
        opacity: 0.6;
        animation: floatOrb 20s infinite ease-in-out alternate;
        pointer-events: none;
    }
    body::before {
        background: rgba(59, 130, 246, 0.6);
        top: -10vh; left: -10vw;
    }
    body::after {
        background: rgba(16, 185, 129, 0.4);
        bottom: -10vh; right: -10vw;
        animation-delay: -10s;
        animation-duration: 25s;
    }

    @@keyframes floatOrb {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(10vw, 15vh) scale(1.1); }
        100% { transform: translate(-10vw, 10vh) scale(0.9); }
    }

    .auth-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
        position: relative;
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px) saturate(180%);
        -webkit-backdrop-filter: blur(12px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
        width: 100%;
        max-width: 580px;
        overflow: hidden;
        transform: translateY(0);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
        animation: scaleIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .auth-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3);
    }

    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.95) translateY(40px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .auth-banner {
        width: 100%;
        height: 120px;
        object-fit: cover;
        border-bottom: 1px solid #e2e8f0;
    }

    .auth-body {
        padding: 2.5rem;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-icon {
        font-size: 3rem;
        color: #3b82f6;
        margin-bottom: 0.5rem;
        display: inline-block;
        filter: drop-shadow(0 2px 4px rgba(59, 130, 246, 0.3));
        animation: floatIcon 4s ease-in-out infinite;
    }

    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0px) scale(1); filter: drop-shadow(0 2px 4px rgba(59, 130, 246, 0.3)); }
        50% { transform: translateY(-10px) scale(1.05); filter: drop-shadow(0 8px 12px rgba(59, 130, 246, 0.5)); }
    }

    .auth-header h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.5rem 0;
        letter-spacing: -0.025em;
    }

    .auth-header p {
        color: #475569;
        font-size: 0.95rem;
        margin: 0;
    }

    .document-requirements {
        background: #f0f9ff;
        border-left: 4px solid #3b82f6;
        padding: 1rem;
        border-radius: 0 8px 8px 0;
        margin-bottom: 1.5rem;
        color: #0f172a;
        transition: transform 0.3s ease;
    }
    
    .document-requirements:hover {
        transform: translateX(5px);
    }

    .document-requirements ul {
        margin: 0;
        padding-left: 1.5rem;
        font-size: 0.85rem;
        color: #475569;
    }

    .form-label {
        color: #1e293b;
        font-weight: 500;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .form-control, .input-group-text, .input-group {
        transition: all 0.3s ease;
    }

    .input-group:focus-within {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.05);
    }

    .form-control {
        background: #ffffff;
        border: 1px solid #cbd5e1;
        color: #0f172a;
        border-radius: 10px;
        padding: 0.75rem 1rem;
    }

    .form-control:focus {
        background: #ffffff;
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        color: #0f172a;
        outline: none;
    }

    .form-control::placeholder {
        color: #94a3b8;
    }

    .input-group-text {
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        border-right: none;
        color: #64748b;
    }

    .form-control.with-icon {
        border-left: none;
    }

    .upload-section {
        background: #f8fafc;
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .upload-section:hover {
        border-color: #3b82f6;
        background: #f0f9ff;
        transform: scale(1.02);
    }

    .upload-section i {
        font-size: 2.2rem;
        color: #64748b;
        margin-bottom: 0.5rem;
        transition: transform 0.3s ease, color 0.3s ease;
    }
    
    .upload-section:hover i {
        transform: translateY(-5px);
        color: #3b82f6;
    }

    .upload-preview {
        max-width: 100%;
        max-height: 200px;
        border-radius: 8px;
        margin-top: 1rem;
        display: none;
        animation: scaleIn 0.4s ease;
    }

    .btn-primary {
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        background-size: 200% auto;
        border: none;
        padding: 0.875rem;
        border-radius: 10px;
        font-weight: 600;
        letter-spacing: 0.025em;
        width: 100%;
        transition: all 0.4s ease;
        margin-top: 1rem;
        color: #ffffff;
        box-shadow: 0 4px 14px 0 rgba(37, 99, 235, 0.2);
    }

    .btn-primary:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 8px 25px rgba(37, 99, 235, 0.4);
        background-position: right center;
    }

    .auth-footer {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.95rem;
        color: #475569;
    }

    .auth-footer a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
    }

    .auth-footer a:hover {
        color: #1e40af;
        text-decoration: underline;
    }
</style>

<div class="auth-container py-4">
    <div class="auth-card">
        <img src="/images/banner.png" alt="Registration Banner" class="auth-banner" />
        <div class="auth-body">
            <div class="auth-header">
                <i class="bi bi-shield-lock auth-icon"></i>
                <h2>Contributor Registration</h2>
                <p>Join the Dire Dawa Hub community</p>
            </div>

            <div class="document-requirements">
                <strong class="text-primary"><i class="bi bi-info-circle me-1"></i> Document Requirements:</strong>
                <ul class="mt-2">
                    <li>Upload a clear photo of your <strong>Work ID card</strong> or <strong>Government ID</strong></li>
                    <li>All text on the ID must be clearly visible</li>
                    <li>File size: Max 5MB (JPG, PNG, PDF accepted)</li>
                    <li>Optional: Include a selfie holding the ID for faster verification</li>
                </ul>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control with-icon" placeholder="name@gov.et" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="WorkId" class="form-label">Work ID Number</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
                            <input asp-for="WorkId" class="form-control with-icon" placeholder="e.g. DD-WBS-3829" />
                        </div>
                        <span asp-validation-for="WorkId" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="DocumentType" class="form-label">Document Type</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-file-earmark-text"></i></span>
                        <select asp-for="DocumentType" class="form-control with-icon">
                            <option value="WorkId">Municipal Employee Work ID</option>
                            <option value="GovernmentId">National Government ID</option>
                            <option value="MunicipalEmployeeCard">Municipal Employee Card</option>
                            <option value="Passport">Passport</option>
                            <option value="DriverLicense">Driver's License</option>
                        </select>
                    </div>
                </div>

                <!-- ID Document Upload -->
                <div class="mb-4">
                    <label asp-for="IdDocumentPhoto" class="form-label">ID Document Photo <span class="text-danger">*</span></label>
                    <div class="upload-section" onclick="document.getElementById('idPhotoInput').click()">
                        <i class="bi bi-cloud-arrow-up"></i>
                        <p class="mb-1 fw-medium" style="color: #1e293b;">Click to upload ID document</p>
                        <p class="small mb-0" style="color: #64748b;">or drag and drop here</p>
                        <input asp-for="IdDocumentPhoto" type="file" id="idPhotoInput" class="d-none" accept="image/*,.pdf" onchange="previewImage(this, 'idPreview')" />
                        <img id="idPreview" class="upload-preview mx-auto" />
                    </div>
                    <span asp-validation-for="IdDocumentPhoto" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Selfie Upload (Optional) -->
                <div class="mb-4">
                    <label asp-for="SelfieWithId" class="form-label">Selfie with ID <span style="color: #64748b; font-weight: normal;">(Optional)</span></label>
                    <div class="upload-section" onclick="document.getElementById('selfieInput').click()">
                        <i class="bi bi-camera"></i>
                        <p class="mb-1 fw-medium" style="color: #1e293b;">Click to upload selfie</p>
                        <p class="small mb-0" style="color: #64748b;">Shows your face clearly holding the ID</p>
                        <input asp-for="SelfieWithId" type="file" id="selfieInput" class="d-none" accept="image/*" onchange="previewImage(this, 'selfiePreview')" />
                        <img id="selfiePreview" class="upload-preview mx-auto" />
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" type="password" class="form-control with-icon" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control with-icon" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary text-white">
                    <i class="bi bi-shield-check me-2"></i>Submit for Verification
                </button>
                
                <div class="auth-footer">
                    Already have an account? <a asp-action="Login">Sign in here</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function previewImage(input, previewId) {
        const preview = document.getElementById(previewId);
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
