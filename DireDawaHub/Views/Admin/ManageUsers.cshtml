@model List<DireDawaHub.ViewModels.AdminUserViewModel>
@{
    ViewData["Title"] = "Identity & Role Manager";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="fw-bold mb-1" style="color: #111827;">System Directory</h2>
        <p class="text-muted mb-0">Verify Work IDs and promote registered users to Contributors.</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Email / User</th>
                    <th class="py-3 text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Work ID</th>
                    <th class="py-3 text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Current Role</th>
                    <th class="pe-4 py-3 text-uppercase text-muted text-end" style="font-size: 0.75rem; letter-spacing: 1px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@user.Email</div>
                            <div class="small text-muted font-monospace">@user.Id.Substring(0, 8)...</div>
                        </td>
                        <td>
                            @if(user.WorkId != "N/A") {
                                <span class="badge bg-secondary text-dark bg-opacity-25 border border-secondary px-2 py-1"><i class="bi bi-briefcase me-1"></i> @user.WorkId</span>
                            } else {
                                <span class="text-muted small italic">Not provided</span>
                            }
                        </td>
                        <td>
                            @if (user.Roles.Contains("Admin"))
                            {
                                <span class="badge bg-danger">Administrator</span>
                            }
                            else if (user.Roles.Contains("Contributor"))
                            {
                                <span class="badge bg-primary">Verified Contributor</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark border border-warning">Pending Review</span>
                            }
                        </td>
                        <td class="pe-4 text-end">
                            @if (!user.Roles.Contains("Admin") && !user.Roles.Contains("Contributor"))
                            {
                                <form asp-action="Promote" method="post" class="d-inline">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-success fw-bold text-white shadow-sm" style="border-radius: 6px;">
                                        <i class="bi bi-shield-check"></i> Approve Contributor
                                    </button>
                                </form>
                            }
                            else if (user.Roles.Contains("Contributor"))
                            {
                                <span class="text-muted small"><i class="bi bi-check-circle-fill text-success"></i> Approved</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
