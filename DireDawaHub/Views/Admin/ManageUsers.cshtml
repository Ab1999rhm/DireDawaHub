@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<DireDawaHub.SharedResource> localizer
@model List<DireDawaHub.ViewModels.AdminUserViewModel>
@{
    ViewData["Title"] = @localizer["Identity Registry"];
}

<style>
    :root {
        --admin-primary: #3b82f6;
        --admin-dark: #0f172a;
        --glass-bg: rgba(15, 23, 42, 0.7);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    body {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.97) 0%, rgba(30, 64, 175, 0.95) 100%),
                    url('/images/smart_banner.png');
        background-size: cover;
        background-attachment: fixed;
        color: #f8fafc;
    }

    .registry-header h2, .registry-header p {
        color: #ffffff !important;
    }

    .registry-header {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        animation: fadeInDown 0.6s ease;
    }

    .admin-table-container {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border-radius: 16px;
        border: 1px solid var(--glass-border);
        overflow: hidden;
        animation: fadeInUp 0.8s ease;
    }

    .table { color: #cbd5e1; }
    .table thead th {
        background: rgba(255, 255, 255, 0.05);
        color: #94a3b8;
        padding: 1rem 1.5rem;
        border: none;
    }
    .table tbody td {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .badge-admin { background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }
    .badge-contributor { background: rgba(59, 130, 246, 0.2); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.3); }
    .badge-pending { background: rgba(245, 158, 11, 0.2); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }

    @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    /* Search & Filter Styles */
    .search-filter-bar {
        background: rgba(15, 23, 42, 0.5);
        border-bottom: 1px solid var(--glass-border);
        padding: 1rem 1.5rem;
    }

    .search-input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #f8fafc;
        border-radius: 8px;
        padding: 0.5rem 1rem;
    }

    .search-input:focus {
        background: rgba(255, 255, 255, 0.08);
        border-color: #3b82f6;
        outline: none;
        color: #f8fafc;
    }

    .search-input::placeholder {
        color: #64748b;
    }

    .filter-select {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #f8fafc;
        border-radius: 8px;
        padding: 0.5rem 1rem;
    }

    .filter-select:focus {
        background: rgba(255, 255, 255, 0.08);
        border-color: #3b82f6;
        outline: none;
    }

    .filter-select option {
        background: #1e293b;
        color: #f8fafc;
    }

    /* Pagination Styles */
    .pagination-container {
        background: rgba(15, 23, 42, 0.5);
        border-top: 1px solid var(--glass-border);
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .pagination {
        margin: 0;
        gap: 0.25rem;
    }

    .pagination .page-link {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #94a3b8;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .pagination .page-link:hover {
        background: rgba(59, 130, 246, 0.2);
        border-color: rgba(59, 130, 246, 0.3);
        color: #60a5fa;
    }

    .pagination .page-item.active .page-link {
        background: rgba(59, 130, 246, 0.3);
        border-color: #3b82f6;
        color: #ffffff;
    }

    .pagination .page-item.disabled .page-link {
        background: rgba(255, 255, 255, 0.02);
        border-color: rgba(255, 255, 255, 0.05);
        color: #475569;
        cursor: not-allowed;
    }

    .results-info {
        color: #94a3b8;
        font-size: 0.875rem;
    }

    /* Bulk Actions */
    .bulk-actions-bar {
        background: rgba(59, 130, 246, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(59, 130, 246, 0.3);
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .user-checkbox {
        width: 18px;
        height: 18px;
        border-radius: 4px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        background: transparent;
        cursor: pointer;
        accent-color: #3b82f6;
    }
</style>

<!-- Breadcrumb Navigation -->
<nav class="breadcrumb-nav">
    <span class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></span>
    <span class="breadcrumb-divider">/</span>
    <span class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Admin</a></span>
    <span class="breadcrumb-divider">/</span>
    <span class="breadcrumb-item active">@localizer["Identity Registry"]</span>
</nav>

<div class="container-fluid px-4 py-3">
    <div class="registry-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1"><i class="bi bi-person-badge me-2"></i> @localizer["Identity & Role Manager"]</h2>
                <p class="text-muted mb-0">@localizer["Verify municipal work IDs and authorize contributor credentials for the community platform."]</p>
            </div>
            <div class="text-end">
                <a href="@Url.Action("ExportUsersToCsv")" class="btn btn-outline-success btn-sm mb-2">
                    <i class="bi bi-filetype-csv me-1"></i> @localizer["Export CSV"]</a>
                </a>
                <div class="small text-muted">@localizer["Total Users"]</div>
                <div class="fs-4 fw-bold text-white">@ViewBag.TotalUsers</div>
            </div>
        </div>
    </div>

    <div class="admin-table-container">
        <!-- Search & Filter Bar -->
        <div class="search-filter-bar">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="small text-muted mb-1">@localizer["Search"]</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-muted" style="border-right: none;">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="searchTerm" class="search-input form-control" placeholder="@localizer["Search by email or username..."]" 
                               value="@ViewBag.SearchTerm" style="border-left: none;" />
                    </div>
                </div>
                <div class="col-md-5">
                    <label class="small text-muted mb-1">@localizer["Quick Filters"]</label>
                    <div class="filter-chips">
                        <a href="@Url.Action("ManageUsers", new { searchTerm = ViewBag.SearchTerm, filterRole = "", pageSize = ViewBag.PageSize })" 
                           class="filter-chip @(string.IsNullOrEmpty(ViewBag.FilterRole) ? "active" : "")">@localizer["All Users"]</a>
                        <a href="@Url.Action("ManageUsers", new { searchTerm = ViewBag.SearchTerm, filterRole = "Admin", pageSize = ViewBag.PageSize })" 
                           class="filter-chip @(ViewBag.FilterRole == "Admin" ? "active" : "")">@localizer["Admins"]</a>
                        <a href="@Url.Action("ManageUsers", new { searchTerm = ViewBag.SearchTerm, filterRole = "Contributor", pageSize = ViewBag.PageSize })" 
                           class="filter-chip @(ViewBag.FilterRole == "Contributor" ? "active" : "")">@localizer["Contributors"]</a>
                        <a href="@Url.Action("ManageUsers", new { searchTerm = ViewBag.SearchTerm, filterRole = "Pending", pageSize = ViewBag.PageSize })" 
                           class="filter-chip @(ViewBag.FilterRole == "Pending" ? "active" : "")">@localizer["Pending"]</a>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="small text-muted mb-1">@localizer["Per Page"]</label>
                    <select name="pageSize" class="filter-select form-select" onchange="this.form.submit()">
                        <option value="10" selected="@(ViewBag.PageSize == 10 ? "selected" : null)">10</option>
                        <option value="25" selected="@(ViewBag.PageSize == 25 ? "selected" : null)">25</option>
                        <option value="50" selected="@(ViewBag.PageSize == 50 ? "selected" : null)">50</option>
                        <option value="100" selected="@(ViewBag.PageSize == 100 ? "selected" : null)">100</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-1"></i> @localizer["Apply"]
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm) || !string.IsNullOrWhiteSpace(ViewBag.FilterRole))
                {
                    <div class="col-12">
                        <a href="@Url.Action("ManageUsers")" class="btn btn-sm btn-outline-light border-opacity-25">
                            <i class="bi bi-x-circle me-1"></i> @localizer["Clear Filters"]
                        </a>
                        @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
                        {
                            <span class="badge bg-info bg-opacity-25 text-info ms-2">
                                <i class="bi bi-search"></i> "@ViewBag.SearchTerm"
                            </span>
                        }
                        @if (!string.IsNullOrWhiteSpace(ViewBag.FilterRole))
                        {
                            <span class="badge bg-warning bg-opacity-25 text-warning ms-2">
                                <i class="bi bi-filter"></i> @ViewBag.FilterRole
                            </span>
                        }
                    </div>
                }
            </form>
        </div>

        <!-- Bulk Actions Bar -->
        <div class="bulk-actions-bar" id="bulkActionsBar" style="display: none;">
            <input type="checkbox" class="user-checkbox" id="selectAllCheckbox" onclick="toggleSelectAll()" />
            <label for="selectAllCheckbox" class="text-white mb-0 ms-2">@localizer["Select All"]</label>
            <span class="text-muted mx-2">|</span>
            <span class="text-light" id="selectedCount"> @localizer["selected"]</span>
            <div class="ms-auto d-flex gap-2">
                <button type="button" class="btn btn-sm btn-success" onclick="bulkPromote()">
                    <i class="bi bi-patch-check me-1"></i> @localizer["Activate Selected"]
                </button>
                <button type="button" class="btn btn-sm btn-warning" onclick="bulkDemote()">
                    <i class="bi bi-slash-circle me-1"></i> @localizer["Deactivate Selected"]
                </button>
                <button type="button" class="btn btn-sm btn-danger" onclick="bulkDelete()">
                    <i class="bi bi-trash3 me-1"></i> @localizer["Delete Selected"]
                </button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 40px;">
                            <input type="checkbox" class="user-checkbox" id="selectAllTop" onclick="toggleSelectAll()" />
                        </th>
                        <th>@localizer["Email / Identity ID"]</th>
                        <th>@localizer["Work Verification ID"]</th>
                        <th>@localizer["Auth Status"]</th>
                        <th class="text-end pe-4">@localizer["Permissions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="user-row" data-user-id="@user.Id" onmouseenter="showHoverCard(this, '@user.Id', '@user.Email', '@(user.WorkId != "N/A" ? user.WorkId : "Not Set")', '@string.Join(",", user.Roles)')" onmouseleave="hideHoverCard()">
                            <td class="ps-4">
                                <input type="checkbox" class="user-checkbox user-select-checkbox" value="@user.Id" onclick="updateBulkActions()" />
                            </td>
                            <td>
                                <div class="fw-bold text-white">@user.Email</div>
                                <div class="small text-muted font-monospace">UUID: @user.Id.Substring(0, 8)...</div>
                            </td>
                            <td>
                                @if(user.WorkId != "N/A") {
                                    <span class="badge bg-secondary text-white bg-opacity-25 border border-secondary px-3 py-2">
                                        <i class="bi bi-shield-check me-2"></i> @user.WorkId
                                    </span>
                                } else {
                                    <span class="text-muted small italic">@localizer["General Public"]</span>
                                }
                            </td>
                            <td>
                                @if (user.Roles.Contains("Admin"))
                                {
                                    <span class="badge badge-admin px-3 py-2">@localizer["System Administrator"]</span>
                                }
                                else if (user.Roles.Contains("Contributor"))
                                {
                                    <span class="badge badge-contributor px-3 py-2">@localizer["Verified Contributor"]</span>
                                }
                                else
                                {
                                    <span class="badge badge-pending px-3 py-2">@localizer["Pending Authorization"]</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-sm btn-outline-light me-1" style="border-radius: 8px;" title="@localizer["Verify ID"]">
                                    <i class="bi bi-eye"></i>
                                </a>
                                
                                @if (!user.Roles.Contains("Admin"))
                                {
                                    if (user.Roles.Contains("Contributor"))
                                    {
                                        <form asp-action="Demote" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning me-1" style="border-radius: 8px;" onclick="return confirm('@localizer["Restrict access for this contributor?"]');">
                                                <i class="bi bi-slash-circle"></i> @localizer["Deactivate"]
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Promote" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-primary fw-bold me-1" style="border-radius: 8px;">
                                                <i class="bi bi-patch-check"></i> @localizer["Activate"]
                                            </button>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="pagination-container">
                <div class="results-info">
                    @localizer["Showing"] @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) - @(Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalUsers)) 
                    @localizer["of"] @ViewBag.TotalUsers @localizer["users"]
                </div>
                <nav aria-label="Page navigation">
                    <ul class="pagination">
                        <!-- First Page -->
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("ManageUsers", new { page = 1, pageSize = ViewBag.PageSize, searchTerm = ViewBag.SearchTerm, filterRole = ViewBag.FilterRole })">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>
                        
                        <!-- Previous Page -->
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("ManageUsers", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize, searchTerm = ViewBag.SearchTerm, filterRole = ViewBag.FilterRole })">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        
                        <!-- Page Numbers -->
                        @{
                            int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                            int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                        }
                        
                        @if (startPage > 1)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                        
                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("ManageUsers", new { page = i, pageSize = ViewBag.PageSize, searchTerm = ViewBag.SearchTerm, filterRole = ViewBag.FilterRole })">@i</a>
                            </li>
                        }
                        
                        @if (endPage < ViewBag.TotalPages)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                        
                        <!-- Next Page -->
                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("ManageUsers", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize, searchTerm = ViewBag.SearchTerm, filterRole = ViewBag.FilterRole })">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                        
                        <!-- Last Page -->
                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("ManageUsers", new { page = ViewBag.TotalPages, pageSize = ViewBag.PageSize, searchTerm = ViewBag.SearchTerm, filterRole = ViewBag.FilterRole })">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        else
        {
            <div class="pagination-container">
                <div class="results-info">Showing @Model.Count of @ViewBag.TotalUsers users</div>
            </div>
        }
    </div>
</div>

<!-- Bulk Operations JavaScript -->
<script>
    function toggleSelectAll() {
        const checkboxes = document.querySelectorAll('.user-select-checkbox');
        const selectAllTop = document.getElementById('selectAllTop');
        const selectAllCheckbox = document.getElementById('selectAllCheckbox');
        const isChecked = selectAllTop.checked || selectAllCheckbox.checked;
        
        checkboxes.forEach(cb => cb.checked = isChecked);
        updateBulkActions();
    }

    function updateBulkActions() {
        const checkboxes = document.querySelectorAll('.user-select-checkbox:checked');
        const count = checkboxes.length;
        const bulkBar = document.getElementById('bulkActionsBar');
        const selectedCount = document.getElementById('selectedCount');
        
        if (count > 0) {
            bulkBar.style.display = 'flex';
            selectedCount.textContent = count + ' selected';
        } else {
            bulkBar.style.display = 'none';
        }
        
        // Sync checkboxes
        const allCheckboxes = document.querySelectorAll('.user-select-checkbox');
        const allChecked = allCheckboxes.length > 0 && allCheckboxes.length === count;
        document.getElementById('selectAllTop').checked = allChecked;
        document.getElementById('selectAllCheckbox').checked = allChecked;
    }

    function bulkPromote() {
        const selectedIds = Array.from(document.querySelectorAll('.user-select-checkbox:checked')).map(cb => cb.value);
        if (selectedIds.length === 0) return;
        
        if (!confirm('Activate ' + selectedIds.length + ' selected user(s) as contributors?')) return;
        
        // Submit via form
        const form = document.createElement('form');
        form.method = 'post';
        form.action = '@Url.Action("BulkPromote")';
        
        selectedIds.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'userIds';
            input.value = id;
            form.appendChild(input);
        });
        
        document.body.appendChild(form);
        form.submit();
    }

    function bulkDemote() {
        const selectedIds = Array.from(document.querySelectorAll('.user-select-checkbox:checked')).map(cb => cb.value);
        if (selectedIds.length === 0) return;
        
        if (!confirm('Deactivate ' + selectedIds.length + ' selected contributor(s)?')) return;
        
        const form = document.createElement('form');
        form.method = 'post';
        form.action = '@Url.Action("BulkDemote")';
        
        selectedIds.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'userIds';
            input.value = id;
            form.appendChild(input);
        });
        
        document.body.appendChild(form);
        form.submit();
    }

    function bulkDelete() {
        const selectedIds = Array.from(document.querySelectorAll('.user-select-checkbox:checked')).map(cb => cb.value);
        if (selectedIds.length === 0) return;
        
        if (!confirm('WARNING: Permanently delete ' + selectedIds.length + ' selected user account(s)? This cannot be undone!')) return;
        
        const form = document.createElement('form');
        form.method = 'post';
        form.action = '@Url.Action("BulkDelete")';
        
        selectedIds.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'userIds';
            input.value = id;
            form.appendChild(input);
        });
        
        document.body.appendChild(form);
        form.submit();
    }

    // Hover Card Functions
    let hoverCardTimeout;
    
    function showHoverCard(row, userId, email, workId, roles) {
        const existingCard = document.querySelector('.user-hover-card');
        if (existingCard) existingCard.remove();
        
        const rect = row.getBoundingClientRect();
        const card = document.createElement('div');
        card.className = 'user-hover-card';
        
        const roleBadges = roles.split(',').map(r => {
            if (r === 'Admin') return '<span class="badge bg-danger bg-opacity-25 text-danger border border-danger">Admin</span>';
            if (r === 'Contributor') return '<span class="badge bg-success bg-opacity-25 text-success border border-success">Contributor</span>';
            return '<span class="badge bg-warning bg-opacity-25 text-warning border border-warning">Pending</span>';
        }).join(' ');
        
        card.innerHTML = `
            <div class="hover-card-header">
                <div class="hover-avatar">${email.charAt(0).toUpperCase()}</div>
                <div class="hover-info">
                    <div class="hover-email">${email}</div>
                    <div class="hover-roles">${roleBadges}</div>
                </div>
            </div>
            <div class="hover-card-body">
                <div class="hover-row">
                    <span class="hover-label">Work ID:</span>
                    <span class="hover-value">${workId}</span>
                </div>
                <div class="hover-row">
                    <span class="hover-label">User ID:</span>
                    <span class="hover-value font-monospace">${userId.substring(0, 12)}...</span>
                </div>
            </div>
            <div class="hover-card-footer">
                <small class="text-muted">Click row to view full details</small>
            </div>
        `;
        
        card.style.cssText = `
            position: fixed;
            left: ${rect.right + 10}px;
            top: ${rect.top}px;
            background: rgba(15, 23, 42, 0.98);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 1rem;
            min-width: 280px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
            z-index: 1000;
            backdrop-filter: blur(10px);
            animation: fadeIn 0.2s ease;
        `;
        
        // Add hover card styles if not exists
        if (!document.querySelector('#hover-card-styles')) {
            const style = document.createElement('style');
            style.id = 'hover-card-styles';
            style.textContent = `
                .user-hover-card .hover-card-header {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    margin-bottom: 12px;
                    padding-bottom: 12px;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                }
                .user-hover-card .hover-avatar {
                    width: 40px;
                    height: 40px;
                    border-radius: 50%;
                    background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-weight: 700;
                    color: white;
                    font-size: 16px;
                }
                .user-hover-card .hover-email {
                    font-weight: 600;
                    color: #f8fafc;
                    font-size: 14px;
                }
                .user-hover-card .hover-roles {
                    margin-top: 4px;
                }
                .user-hover-card .hover-card-body {
                    margin-bottom: 12px;
                }
                .user-hover-card .hover-row {
                    display: flex;
                    justify-content: space-between;
                    margin-bottom: 8px;
                    font-size: 13px;
                }
                .user-hover-card .hover-label {
                    color: #64748b;
                }
                .user-hover-card .hover-value {
                    color: #94a3b8;
                }
                .user-hover-card .hover-card-footer {
                    padding-top: 8px;
                    border-top: 1px solid rgba(255, 255, 255, 0.05);
                    text-align: center;
                }
            `;
            document.head.appendChild(style);
        }
        
        document.body.appendChild(card);
        
        // Adjust position if card goes off screen
        const cardRect = card.getBoundingClientRect();
        if (cardRect.right > window.innerWidth) {
            card.style.left = `${rect.left - cardRect.width - 10}px`;
        }
        if (cardRect.bottom > window.innerHeight) {
            card.style.top = `${rect.bottom - cardRect.height}px`;
        }
    }
    
    function hideHoverCard() {
        hoverCardTimeout = setTimeout(() => {
            const card = document.querySelector('.user-hover-card');
            if (card) card.remove();
        }, 300);
    }
    
    // Keep card visible when hovering over it
    document.addEventListener('mouseover', function(e) {
        if (e.target.closest('.user-hover-card')) {
            clearTimeout(hoverCardTimeout);
        }
    });
</script>
