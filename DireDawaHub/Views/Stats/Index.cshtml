@model IEnumerable<DireDawaHub.Models.CityStatistic>
@{
    ViewData["Title"] = "Municipal Statistics";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📈 City Statistics</h2>
        @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Contributor")))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4">Add Statistic</a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-3">
                <div class="glass-card p-4 text-center">
                    <div class="fs-1 mb-2">@item.Icon</div>
                    <div class="text-muted small text-uppercase">@item.Label</div>
                    <h3 class="fw-bold my-2 text-white">@item.Value</h3>
                    <div class="badge bg-primary bg-opacity-10 text-primary mb-3">@item.Category</div>
                    
                    @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Contributor")))
                    {
                        <div class="d-flex justify-content-center gap-2 mt-3 pt-3 border-top border-white border-opacity-10">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
