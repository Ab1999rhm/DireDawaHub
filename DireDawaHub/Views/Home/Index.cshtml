@model DireDawaHub.ViewModels.PublicDashboardViewModel
@{
    ViewData["Title"] = @SharedLocalizer["PageTitle"];
}

<style>
    /* ============================================
       DIRE DAWA HUB - PREMIUM DESIGN SYSTEM
       Modern Glassmorphism & High-Contrast UI
       ============================================ */
    :root {
        --dd-primary: #2563eb;
        --dd-primary-dark: #1e40af;
        --dd-accent: #f59e0b;
        --dd-success: #10b981;
        --dd-danger: #ef4444;
        --dd-info: #0ea5e9;
        
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.4);
        --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
        
        --radius-lg: 24px;
        --radius-md: 16px;
        --radius-sm: 12px;
        
        --font-main: 'Inter', system-ui, -apple-system, sans-serif;
    }

    body {
        font-family: var(--font-main);
        color: #f8fafc;
    }

    /* Premium Hero Section */
    .hero-container {
        position: relative;
        overflow: hidden;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        opacity: 0.9;
        max-width: 700px;
        margin: 0 auto 3rem;
    }

    /* Glass Cards */
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        border-radius: var(--radius-md);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .glass-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        border-color: rgba(59, 130, 246, 0.4);
        background: rgba(255, 255, 255, 0.08);
    }

    .glass-card-body {
        padding: 1.5rem;
        flex-grow: 1;
    }

    /* Section Headers */
    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding-top: 3rem;
    }

    .section-title {
        font-size: 1.75rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #ffffff;
    }

    /* Poster Gallery */
    .poster-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .poster-card {
        position: relative;
        border-radius: var(--radius-md);
        overflow: hidden;
        aspect-ratio: 4/5;
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .poster-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .poster-card:hover img {
        transform: scale(1.08);
    }

    .poster-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.9));
        padding: 3rem 1.5rem 1.5rem;
        color: white;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .poster-card:hover .poster-overlay {
        opacity: 1;
        transform: translateY(0);
    }

    /* Stats Bar */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        max-width: 1100px;
        margin: -3.5rem auto 0;
        position: relative;
        z-index: 10;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        padding: 1.75rem 1rem;
        border-radius: var(--radius-md);
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-5px);
    }

    .stat-value {
        font-size: 2.25rem;
        font-weight: 800;
        color: #3b82f6;
        display: block;
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .stat-label {
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    /* Quick Nav */
    .quick-nav-pill {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.8rem 1.6rem;
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(10px);
        border-radius: 100px;
        text-decoration: none !important;
        color: #e2e8f0;
        font-weight: 600;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.1);
        white-space: nowrap;
    }

    .quick-nav-pill:hover {
        background: var(--dd-primary);
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
    }

    /* Weather Widget */
    .weather-widget {
        background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
        color: white;
        padding: 2.5rem;
        border-radius: var(--radius-md);
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 20px 40px rgba(14, 165, 233, 0.2);
    }

    .weather-temp {
        font-size: 4rem;
        font-weight: 800;
        line-height: 1;
    }

    /* Status Badges */
    .badge-status {
        padding: 0.4rem 0.8rem;
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .bg-flowing { background: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
    .bg-delayed { background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
    .bg-scheduled { background: rgba(59, 130, 246, 0.2); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2); }

    .text-muted { color: #94a3b8 !important; }
    .text-primary { color: #60a5fa !important; }

    ::placeholder { color: rgba(255, 255, 255, 0.5) !important; }

    /* Emergency Broadcast */
    .emergency-broadcast-fixed {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        width: calc(100% - 4rem);
        max-width: 1000px;
        background: #dc2626;
        color: white;
        padding: 1.5rem 2rem;
        border-radius: var(--radius-md);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 25px 60px rgba(220, 38, 38, 0.5);
        animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes slideUp {
        from { transform: translate(-50%, 100%); opacity: 0; }
        to { transform: translate(-50%, 0); opacity: 1; }
    }

    /* Notification System */
    .notification-container {
        position: fixed;
        top: 2rem;
        right: 2rem;
        z-index: 3000;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* Custom Scrollbar */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    @@media (max-width: 991px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); width: calc(100% - 2rem); }
        .hero-title { font-size: 2.75rem; }
    }
</style>

@* Emergency Broadcast Section *@
@if (Model.ActiveEmergencyBroadcasts?.Any() == true)
{
    var firstBroadcast = Model.ActiveEmergencyBroadcasts.First();
    <div id="emergencyBar" class="emergency-broadcast-fixed">
        <div class="d-flex align-items-center gap-4">
            <span style="font-size: 2.5rem;">🚨</span>
            <div>
                <strong class="d-block fs-5">@SharedLocalizer["Emergency Broadcast"]</strong>
                <span class="opacity-90">@firstBroadcast.Message</span>
            </div>
        </div>
        <button class="btn btn-light fw-bold px-4 rounded-pill" onclick="acknowledgeBroadcast(@firstBroadcast.Id)">
            CLOSE
        </button>
    </div>
}

<div id="notificationContainer" class="notification-container"></div>

<!-- Hero Section -->
<div class="hero-container text-center" style="background: transparent; padding: 120px 0 80px;">
    <div class="container">
        <div class="badge-premium mb-4" style="background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.3); color: #60a5fa; display: inline-block; backdrop-filter: blur(10px); padding: 8px 20px; border-radius: 100px;">
            <i class="bi bi-broadcast"></i> Live Community Hub
        </div>
        <h1 class="hero-title animate-fade-in text-white fw-bold" style="font-size: 4rem; letter-spacing: -0.04em;">@SharedLocalizer["AppTitle"]</h1>
        <p class="hero-subtitle animate-fade-in opacity-75 text-light" style="animation-delay: 0.1s; font-size: 1.25rem;">@SharedLocalizer["SubTitle"]</p>
        
        <div class="search-wrapper mx-auto mt-5" style="max-width: 650px;">
            <div class="glass-card p-2 d-flex align-items-center" style="border-radius: 100px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(20px);">
                <i class="bi bi-search ms-4 fs-5 opacity-50 text-white"></i>
                <input type="text" id="globalSearch" class="form-control border-0 bg-transparent text-white placeholder-white fs-5 px-3" 
                       placeholder="@SharedLocalizer["SearchPlaceholder"]" style="box-shadow: none;">
                <div class="me-3 d-none d-md-flex gap-1">
                    <kbd class="bg-white bg-opacity-10 text-white border-0 px-2 shadow-sm">CTRL</kbd>
                    <kbd class="bg-white bg-opacity-10 text-white border-0 px-2 shadow-sm">K</kbd>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Bar -->
<div class="container">
    <div class="stats-grid">
        <div class="stat-card animate-fade-in" style="animation-delay: 0.2s;">
            <span class="stat-value">@Model.WaterSchedules.Count()</span>
            <span class="stat-label">@SharedLocalizer["StatWater"]</span>
        </div>
        <div class="stat-card animate-fade-in" style="animation-delay: 0.3s;">
            <span class="stat-value">@Model.Clinics.Count()</span>
            <span class="stat-label">@SharedLocalizer["StatClinics"]</span>
        </div>
        <div class="stat-card animate-fade-in" style="animation-delay: 0.4s;">
            <span class="stat-value">@Model.AgMarkets.Count()</span>
            <span class="stat-label">@SharedLocalizer["StatMarkets"]</span>
        </div>
        <div class="stat-card animate-fade-in" style="animation-delay: 0.5s;">
            <span class="stat-value">@Model.Jobs.Count()</span>
            <span class="stat-label">@SharedLocalizer["StatJobs"]</span>
        </div>
    </div>
</div>

<!-- Category Navigation -->
<div class="container mt-5">
    <div class="d-flex gap-3 overflow-auto pb-3 no-scrollbar justify-content-lg-center">
        <a href="#water-section" class="quick-nav-pill">💧 Water</a>
        <a href="#health-section" class="quick-nav-pill">🏥 Health</a>
        <a href="#market-section" class="quick-nav-pill">🌾 Agriculture</a>
        <a href="#jobs-section" class="quick-nav-pill">💼 Jobs</a>
        <a href="#education-section" class="quick-nav-pill">📚 Education</a>
        <a href="#weather-section" class="quick-nav-pill">🌤️ Weather</a>
        <a href="#posters-section" class="quick-nav-pill">🖼️ Community Posters</a>
    </div>
</div>

<div class="container py-4">
    <!-- Community Posters Section (NEW) -->
    <div id="posters-section" class="mb-5">
        <div class="section-header">
            <h2 class="section-title">🖼️ Community Posters & Announcements</h2>
            <span class="badge bg-primary rounded-pill px-3">HIGHEST QUALITY</span>
        </div>
        <div class="poster-gallery">
            @if (Model.Posters.Any())
            {
                @foreach (var poster in Model.Posters)
                {
                    <div class="poster-card animate-fade-in">
                        <img src="@poster.ImagePath" alt="@poster.Title" loading="lazy">
                        <div class="poster-overlay">
                            <h4 class="fw-bold mb-1">@poster.Title</h4>
                            <p class="small mb-1 opacity-90">@poster.Description</p>
                            @if (!string.IsNullOrEmpty(poster.Location))
                            {
                                <div class="smaller opacity-75"><i class="bi bi-geo-alt"></i> @poster.Location</div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Sample Posters if none exist yet -->
                <div class="poster-card">
                    <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&q=80&w=800" alt="Tech Event">
                    <div class="poster-overlay">
                        <h4 class="fw-bold mb-1">Tech In Dire Dawa</h4>
                        <p class="small mb-0 opacity-90">Coming this summer to the community center.</p>
                    </div>
                </div>
                <div class="poster-card">
                    <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&q=80&w=800" alt="Yoga Class">
                    <div class="poster-overlay">
                        <h4 class="fw-bold mb-1">Morning Yoga</h4>
                        <p class="small mb-0 opacity-90">Join us every Saturday at 7 AM in the park.</p>
                    </div>
                </div>
                <div class="poster-card">
                    <img src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?auto=format&fit=crop&q=80&w=800" alt="Music Festival">
                    <div class="poster-overlay">
                        <h4 class="fw-bold mb-1">Cultural Music Night</h4>
                        <p class="small mb-0 opacity-90">Celebrating our rich heritage through sound.</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Weather & Education Grid -->
    <div class="row g-4 mb-5">
        <div id="weather-section" class="col-lg-6">
            <div class="weather-widget glass-card">
                <div>
                    <h3 class="fw-bold mb-0">Dire Dawa, Ethiopia</h3>
                    <p class="mb-4 opacity-75">@DateTime.Now.ToString("dddd, MMMM dd")</p>
                    <div class="d-flex align-items-center gap-3">
                        <span class="weather-temp">@Model.Weather.Temperature°C</span>
                        <div>
                            <div class="fw-bold fs-5">@Model.Weather.Condition</div>
                            <div class="small">Feels like 30°C</div>
                        </div>
                    </div>
                </div>
                <div style="font-size: 5rem;">@Model.Weather.Icon</div>
            </div>
        </div>
        <div id="education-section" class="col-lg-6">
            <div class="glass-card p-4">
                <h3 class="fw-bold mb-4">📚 Education Updates</h3>
                <div class="d-flex flex-column gap-3">
                    @foreach (var edu in Model.EducationAnnouncements)
                    {
                        <div class="p-3 bg-white bg-opacity-10 rounded-3 border border-white border-opacity-10">
                            <h5 class="fw-bold mb-1 text-white">@edu.Title</h5>
                            <p class="small text-muted mb-0">@edu.Description</p>
                            <span class="text-primary smaller fw-bold mt-2 d-inline-block">Event Date: @edu.Date.ToString("MMM dd, yyyy")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Core Services Grid -->
    <div class="row g-4">
        <!-- Water -->
        <div id="water-section" class="col-lg-6">
            <div class="section-header pt-0">
                <h3 class="section-title">💧 @SharedLocalizer["WaterHeader"]</h3>
                <a href="#" class="btn btn-sm btn-link text-primary fw-bold text-decoration-none">VIEW ALL →</a>
            </div>
            <div class="row g-3" id="waterFeed">
                @foreach (var water in Model.WaterSchedules.Take(4))
                {
                    <div class="col-md-6 filterable-item">
                        <div class="glass-card glass-card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="fw-bold text-dark">@water.Location</span>
                                <span class="badge-status @(water.Status == "Active" ? "bg-flowing" : water.Status == "Delayed" ? "bg-delayed" : "bg-scheduled")">
                                    @water.Status
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-2 small text-muted">
                                <i class="bi bi-clock"></i> @water.StartTime.ToString("h:mm tt") - @water.EndTime.ToString("h:mm tt")
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Health -->
        <div id="health-section" class="col-lg-6">
            <div class="section-header pt-0">
                <h3 class="section-title">🏥 @SharedLocalizer["HealthHeader"]</h3>
                <a href="#" class="btn btn-sm btn-link text-primary fw-bold text-decoration-none">VIEW ALL →</a>
            </div>
            <div class="row g-3" id="healthFeed">
                @foreach (var clinic in Model.Clinics.Take(2))
                {
                    <div class="col-12 filterable-item">
                        <div class="glass-card glass-card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="fw-bold mb-1">@clinic.ClinicName</h5>
                                <div class="d-flex gap-3 small text-muted">
                                    <span>👨‍⚕️ @clinic.AvailableDoctors Doctors</span>
                                    <span>📞 @clinic.EmergencyContact</span>
                                </div>
                            </div>
                            <span class="badge @(clinic.HasEssentialMedicines ? "bg-success" : "bg-danger") px-3">
                                @(clinic.HasEssentialMedicines ? "Stock OK" : "Low Stock")
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Jobs & Markets -->
<div class="container py-5">
    <div class="row g-5">
        <div id="market-section" class="col-lg-6">
            <div class="section-header pt-0">
                <h3 class="section-title">🌾 @SharedLocalizer["AgHeader"]</h3>
                <a href="#" class="btn btn-sm btn-link text-primary fw-bold text-decoration-none">LIVE PRICES →</a>
            </div>
            <div class="glass-card" style="padding: 0;">
                @foreach (var ag in Model.AgMarkets.Take(5))
                {
                    <div class="p-3 border-bottom d-flex justify-content-between align-items-center filterable-item">
                        <div class="d-flex align-items-center gap-3">
                            <div class="fs-3">🌾</div>
                            <div>
                                <div class="fw-bold">@ag.CropName</div>
                                <div class="small text-muted">📍 @ag.MarketLocation</div>
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-success fs-5">ETB @ag.PricePerKg.ToString("0.00")</div>
                            <div class="smaller text-muted text-uppercase">Per KG</div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div id="jobs-section" class="col-lg-6">
            <div class="section-header pt-0">
                <h3 class="section-title">💼 @SharedLocalizer["JobsHeader"]</h3>
                <a href="#" class="btn btn-sm btn-link text-primary fw-bold text-decoration-none">ALL JOBS →</a>
            </div>
            <div class="d-flex flex-column gap-3" id="jobsFeed">
                @foreach (var job in Model.Jobs.Take(3))
                {
                    <div class="glass-card glass-card-body filterable-item">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="fw-bold mb-0">@job.Title</h5>
                            <span class="text-muted smaller">@job.PostedDate.ToString("MMM dd")</span>
                        </div>
                        <p class="text-muted small mb-0">🏢 @job.Company • 📍 @job.Location</p>
                        <div class="mt-3">
                            <span class="badge @(job.IsTrainingOpportunity ? "bg-warning text-dark" : "bg-primary") px-3">
                                @(job.IsTrainingOpportunity ? "TRAINING" : "FULL-TIME")
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .hover-white:hover { color: white !important; }
    .text-secondary { color: #94a3b8 !important; }
</style>

<script>
    // Premium Dashboard Interactivity
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("globalSearch");
        const items = document.querySelectorAll(".filterable-item");

        // Global Search with Animation
        searchInput.addEventListener("input", function(e) {
            const term = e.target.value.toLowerCase().trim();
            items.forEach(item => {
                const text = item.textContent.toLowerCase();
                if (text.includes(term)) {
                    item.style.display = "";
                    item.style.opacity = "1";
                    item.style.transform = "scale(1)";
                } else {
                    item.style.opacity = "0";
                    item.style.transform = "scale(0.95)";
                    setTimeout(() => item.style.display = "none", 200);
                }
            });
        });

        // Keyboard Shortcut Ctrl+K
        document.addEventListener("keydown", function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === "k") {
                e.preventDefault();
                searchInput.focus();
            }
        });

        // Smooth Scroll for Category Links
        document.querySelectorAll('.quick-nav-pill').forEach(link => {
            link.addEventListener('click', function(e) {
                const targetId = this.getAttribute('href');
                if (targetId.startsWith('#')) {
                    e.preventDefault();
                    document.querySelector(targetId).scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            });
        });

        // Simple Notification Simulation
        window.NotificationSystem = {
            show(title, msg) {
                const container = document.getElementById('notificationContainer');
                const toast = document.createElement('div');
                toast.className = 'glass-card p-3 border-start border-4 border-primary animate-fade-in';
                toast.innerHTML = `<h6 class="fw-bold mb-1">${title}</h6><p class="small mb-0 text-muted">${msg}</p>`;
                container.appendChild(toast);
                setTimeout(() => toast.remove(), 5000);
            }
        };

        // Emergency Acknowledgment
        window.acknowledgeBroadcast = async function(id) {
            const bar = document.getElementById('emergencyBar');
            bar.style.transform = 'translate(-50%, 100%)';
            bar.style.opacity = '0';
            setTimeout(() => bar.remove(), 600);
            await fetch('/Home/AcknowledgeBroadcast?broadcastId=' + id, { method: 'POST' });
        };
    });
</script>
}
