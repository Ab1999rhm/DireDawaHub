@model DireDawaHub.Models.CommunityPoster
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Back Button -->
            <a asp-action="Index" class="btn btn-outline-light border-opacity-25 mb-4 rounded-pill">
                <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
            </a>

            <div class="glass-card overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-6">
                        <img src="@Model.ImagePath" alt="@Model.Title" class="img-fluid h-100 object-fit-cover w-100" style="max-height: 600px;">
                    </div>
                    <div class="col-md-6 p-4 p-lg-5 d-flex flex-column">
                        <div class="badge bg-primary bg-opacity-20 text-primary mb-3 align-self-start px-3 py-2 rounded-pill">
                            @Model.Category
                        </div>
                        <h1 class="display-5 fw-bold text-white mb-4">@Model.Title</h1>
                        
                        <div class="d-flex align-items-center gap-4 mb-4 text-muted small">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-calendar3"></i> @Model.PostedDate.ToString("MMM dd, yyyy")
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Location))
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-geo-alt"></i> @Model.Location
                                </div>
                            }
                        </div>

                        <p class="lead text-light opacity-75 mb-4" style="line-height: 1.8;">
                            @Model.Description
                        </p>

                        <div class="poster-content text-light" style="line-height: 1.7;">
                            @Html.Raw(Model.Content?.Replace("\n", "<br/>"))
                        </div>

                        <hr class="my-5 border-white border-opacity-10">

                        <div class="mt-auto d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-2">
                                <i class="bi bi-share text-primary"></i>
                            </div>
                            <span class="text-muted small">Share this community update</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .object-fit-cover { object-fit: cover; }
    .poster-content { font-size: 1.1rem; }
</style>
