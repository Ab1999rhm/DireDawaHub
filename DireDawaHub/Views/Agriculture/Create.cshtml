@model DireDawaHub.Models.AgricultureMarket
@{
    ViewData["Title"] = "Record Market Price";
}

<div class="card shadow-sm border-0" style="border-radius: 12px; max-width: 600px; margin: 0 auto; margin-top: 20px;">
    <div class="card-body p-5">
        <h3 class="mb-4 fw-bold text-success">Report Market Price</h3>
        
        <form asp-action="Create">
            <div class="row">
                <div class="col-md-8 mb-4">
                    <label asp-for="CropName" class="form-label fw-bold text-muted small text-uppercase">Crop / Produce Name</label>
                    <input asp-for="CropName" class="form-control" style="padding: 12px; border-radius: 8px;" placeholder="e.g. Teff, Sorghum, Onion" required />
                </div>
                <div class="col-md-4 mb-4">
                    <label asp-for="PricePerKg" class="form-label fw-bold text-muted small text-uppercase">Price (ETB / KG)</label>
                    <input asp-for="PricePerKg" class="form-control" type="number" step="0.01" style="padding: 12px; border-radius: 8px;" required />
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="MarketLocation" class="form-label fw-bold text-muted small text-uppercase">Market Name</label>
                <input asp-for="MarketLocation" class="form-control" style="padding: 12px; border-radius: 8px;" placeholder="e.g. Ashawa Market" required />
            </div>

            <div class="mb-5 p-4 border rounded-3 bg-danger bg-opacity-10 border-danger border-opacity-25">
                <label asp-for="DiseaseAlerts" class="form-label fw-bold text-danger text-uppercase"><i class="bi bi-exclamation-triangle"></i> Crop Disease Alerts (Optional)</label>
                <textarea asp-for="DiseaseAlerts" class="form-control" rows="3" style="padding: 12px; border-radius: 8px;" placeholder="Any pests or diseases farmers should be warned about?"></textarea>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="text-muted text-decoration-none fw-bold">← Cancel</a>
                <button type="submit" class="btn btn-success px-5 py-2 fw-bold text-white" style="border-radius: 8px; font-size: 1.1rem;">Submit Report</button>
            </div>
        </form>
    </div>
</div>
