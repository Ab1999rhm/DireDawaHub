@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.AspNetCore.Identity
@inject IHtmlLocalizer<DireDawaHub.SharedResource> localizer
@model IdentityUser
@{
    ViewData["Title"] = "Command Center";
    var state = (DireDawaHub.Services.SystemStateService)ViewBag.SystemState;
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 admin-header-anim">
        <div>
            <h1 class="fw-bold mb-0">🛡️ @localizer["HUB COMMAND CENTER"]</h1>
            <p class="text-muted">@localizer["Global Synchronization & System Governance"]</p>
        </div>
        <div class="d-flex gap-3">
            <a asp-action="DownloadLogs" class="admin-btn admin-btn-outline">
                <i class="bi bi-download me-2"></i> @localizer["Export Logs"]
            </a>
            <a asp-action="ManageUsers" class="admin-btn admin-btn-primary">
                👥 @localizer["Manage Access"]
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="admin-card text-center" style="animation-delay: 0.1s;">
                <div class="fs-4">👤</div>
                <div class="text-muted x-small text-uppercase">@localizer["Total Users"]</div>
                <h4 class="fw-bold mb-0">@ViewBag.TotalUsers</h4>
                <div class="small text-success">@ViewBag.TotalContributors @localizer["Contributors"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center" style="animation-delay: 0.2s;">
                <div class="fs-4">💧</div>
                <div class="text-muted x-small text-uppercase">@localizer["Water Records"]</div>
                <h4 class="fw-bold mb-0">@ViewBag.TotalWaterRecords</h4>
                <div class="small text-success">@localizer["Active Schedules"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center" style="animation-delay: 0.3s;">
                <div class="fs-4">💼</div>
                <div class="text-muted x-small text-uppercase">@localizer["Job Postings"]</div>
                <h4 class="fw-bold mb-0">@ViewBag.TotalJobs</h4>
                <div class="small @(ViewBag.PendingJobs > 0 ? "text-warning" : "text-success")">
                    @ViewBag.ActiveJobs @localizer["Active"] / @ViewBag.PendingJobs @localizer["Pending"]
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center" style="animation-delay: 0.35s;">
                <div class="fs-4">🏥</div>
                <div class="text-muted x-small text-uppercase">@localizer["Healthcare"]</div>
                <h4 class="fw-bold mb-0">@ViewBag.TotalClinics</h4>
                <div class="small text-success">@localizer["Active Clinics"]</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="admin-card" style="animation-delay: 0.4s;">
                <h6 class="fw-bold small text-uppercase mb-3"><i class="bi bi-hdd-network me-2"></i> @localizer["System Health"]</h6>
                <div class="d-flex justify-content-between x-small mb-1">
                    <span>@localizer["AGRI-FETCHER SERVICE"]</span>
                    <span class="text-success">@state.ServiceStatus</span>
                </div>
                <div class="integrity-bar">
                    <div class="integrity-fill" style="width: 100%; background: #22c55e;"></div>
                </div>
                <div class="d-flex justify-content-between x-small mb-1 mt-2">
                    <span>@localizer["DATABASE LATENCY"]</span>
                    <span class="text-warning">@state.DatabaseLatency ms</span>
                </div>
                <div class="integrity-bar">
                    <div class="integrity-fill" style="width: 85%; background: #eab308;"></div>
                </div>
                <div class="small text-muted italic mt-2" style="font-size: 0.75rem;">
                    <i class="bi bi-clock-history me-1"></i> @localizer["Last Sync"]: @state.LastAgricultureFetch.ToString("HH:mm:ss")
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="admin-card" style="animation-delay: 0.45s;">
                <h6 class="fw-bold small text-uppercase mb-3"><i class="bi bi-shield-check me-2"></i> @localizer["Security Overview"]</h6>
                <div class="row g-2">
                    <div class="col-6">
                        <div class="d-flex justify-content-between x-small mb-1">
                            <span>@localizer["Verified Contributors"]</span>
                            <span class="text-success">@ViewBag.TotalContributors</span>
                        </div>
                        <div class="integrity-bar">
                            <div class="integrity-fill" style="width: @(ViewBag.TotalUsers > 0 ? (ViewBag.TotalContributors * 100 / ViewBag.TotalUsers) : 0)%; background: #10b981;"></div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex justify-content-between x-small mb-1">
                            <span>@localizer["Pending Approval"]</span>
                            <span class="text-warning">@ViewBag.PendingUsers</span>
                        </div>
                        <div class="integrity-bar">
                            <div class="integrity-fill" style="width: @(ViewBag.TotalUsers > 0 ? (ViewBag.PendingUsers * 100 / ViewBag.TotalUsers) : 0)%; background: #f59e0b;"></div>
                        </div>
                    </div>
                </div>
                <div class="mt-3 text-center">
                    <a asp-action="ManageUsers" class="admin-btn admin-btn-outline btn-sm">
                        <i class="bi bi-people me-1"></i> @localizer["Manage Identity Registry"]
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Emergency Intervention -->
        <div class="col-lg-4">
            <div class="admin-card h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-megaphone me-2"></i> @localizer["Emergency Broadcast"]</h5>
                <form asp-action="BroadcastAlert" method="post">
                    <div class="mb-3">
                        <textarea name="message" class="form-control admin-input" rows="3" placeholder="@localizer["Enter emergency message..."]"></textarea>
                    </div>
                    <button type="submit" class="admin-btn admin-btn-primary w-100" style="background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);">
                        <i class="bi bi-broadcast me-2"></i> @localizer["Trigger Global Alert"]
                    </button>
                </form>
                <div class="mt-4 d-flex flex-column gap-2">
                    <a asp-action="Catalog" class="admin-btn admin-btn-outline w-100">
                        <i class="bi bi-pencil-square me-2"></i> @localizer["Open System Catalog (CRUD)"]
                    </a>
                    <a asp-action="AuditLogs" class="admin-btn admin-btn-outline w-100">
                        <i class="bi bi-journal-text me-2"></i> @localizer["View Full Audit Logs"]
                    </a>
                </div>
            </div>
        </div>

        <!-- Recent Security Audit Logs -->
        <div class="col-lg-8">
            <div class="admin-table-wrapper h-100 d-flex flex-column">
                <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center" style="background: rgba(15, 23, 42, 0.5);">
                    <h5 class="fw-bold mb-0 text-white"><i class="bi bi-shield-lock me-2"></i> @localizer["Security Audit Trail"]</h5>
                    <div class="d-flex gap-2">
                        <span class="admin-badge admin-badge-info">@(ViewBag.RecentAuditLogs?.Count ?? 0) @localizer["Recent Events"]</span>
                        <span class="admin-badge admin-badge-success">@localizer["Live"]</span>
                    </div>
                </div>
                <div class="table-responsive flex-grow-1">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th class="ps-4">@localizer["Time"]</th>
                                <th>@localizer["Action"]</th>
                                <th>@localizer["Description"]</th>
                                <th>@localizer["Performed By"]</th>
                                <th class="text-end pe-4">@localizer["Severity"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentAuditLogs != null)
                            {
                                @foreach (var log in (IEnumerable<DireDawaHub.Models.SecurityAuditLog>)ViewBag.RecentAuditLogs)
                                {
                                    <tr>
                                        <td class="ps-4 small font-monospace text-muted">@log.Timestamp.ToString("MM/dd HH:mm")</td>
                                        <td>
                                            <span class="admin-badge admin-badge-neutral">@log.Action</span>
                                        </td>
                                        <td class="small">@log.Description</td>
                                        <td class="small text-muted">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="admin-avatar-sm" style="width: 24px; height: 24px; font-size: 10px;">
                                                    @(string.IsNullOrEmpty(log.PerformedBy) ? "?" : log.PerformedBy.Substring(0, 1).ToUpper())
                                                </div>
                                                @log.PerformedBy
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            @switch (log.Severity)
                                            {
                                                case AuditSeverity.Info:
                                                    <span class="admin-badge admin-badge-info">ℹ️ @localizer["Info"]</span>
                                                    break;
                                                case AuditSeverity.Warning:
                                                    <span class="admin-badge admin-badge-warning">⚠️ @localizer["Warning"]</span>
                                                    break;
                                                case AuditSeverity.Critical:
                                                    <span class="admin-badge admin-badge-danger">🚨 @localizer["Critical"]</span>
                                                    break;
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4" style="color: #64748b;">
                                        <i class="bi bi-inbox fs-3 d-block mb-2" style="color: #475569;"></i>
                                        @localizer["No audit logs available. Actions will be logged here."]
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Moderation Preview -->
    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="admin-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0 text-white"><i class="bi bi-inboxes me-2"></i> @localizer["Recent Content Submissions"]</h5>
                    <a asp-action="Catalog" class="admin-btn admin-btn-outline btn-sm">@localizer["View All in Catalog"]</a>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <h6 class="text-muted small text-uppercase">@localizer["Recent Job Postings"]</h6>
                        @foreach (var job in (IEnumerable<DireDawaHub.Models.JobPosting>)ViewBag.RecentJobs)
                        {
                            <div class="d-flex justify-content-between align-items-center p-2 mb-2 rounded" style="background: rgba(255,255,255,0.05);">
                                <div>
                                    <div class="small fw-bold">@job.Title</div>
                                    <div class="small text-muted">@job.Company</div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    @if (job.IsApproved)
                                    {
                                        <span class="badge bg-success bg-opacity-25 text-success small">✓ @localizer["Live"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-25 text-warning small">⏳ @localizer["Pending"]</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted small text-uppercase">@localizer["Recent Water Updates"]</h6>
                        @foreach (var water in (IEnumerable<DireDawaHub.Models.WaterSchedule>)ViewBag.RecentWater)
                        {
                            <div class="d-flex justify-content-between align-items-center p-2 mb-2 rounded" style="background: rgba(255,255,255,0.05);">
                                <div>
                                    <div class="small fw-bold">@water.Location</div>
                                    <div class="small text-muted">@water.Status</div>
                                </div>
                                <span class="small text-muted">@water.StartTime.ToString("MM/dd HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
