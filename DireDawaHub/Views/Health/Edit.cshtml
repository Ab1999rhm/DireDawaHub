@model DireDawaHub.Models.ClinicRecord
@{
    ViewData["Title"] = "Edit Clinic Record";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4">🏥 Edit Clinic Status</h2>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="LastUpdated" />
                        
                        <div class="mb-3">
                            <label asp-for="ClinicName" class="form-label fw-bold">Clinic Name</label>
                            <input asp-for="ClinicName" class="form-control rounded-3" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="AvailableDoctors" class="form-label fw-bold">Available Doctors</label>
                            <input asp-for="AvailableDoctors" class="form-control rounded-3" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="EmergencyContact" class="form-label fw-bold">Emergency Contact</label>
                            <input asp-for="EmergencyContact" class="form-control rounded-3" required />
                        </div>

                        <div class="mb-4 d-flex align-items-center gap-3">
                            <div class="form-check form-switch">
                                <input asp-for="HasEssentialMedicines" class="form-check-input" type="checkbox">
                                <label asp-for="HasEssentialMedicines" class="form-check-label fw-bold">Essential Medicines Available</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-3 fw-bold">SAVE CHANGES</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill py-3">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
