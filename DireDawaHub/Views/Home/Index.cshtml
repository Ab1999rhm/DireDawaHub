@model DireDawaHub.ViewModels.PublicDashboardViewModel
@{
    ViewData["Title"] = @SharedLocalizer["PageTitle"];
}

<style>
    /* ============================================
       DIRE DAWA COMMUNITY HUB - DESIGN SYSTEM
       Professional color palette and components
       ============================================ */
    :root {
        /* Primary Brand Colors */
        --dd-primary: #1e40af;        /* Deep Blue - Trust & Authority */
        --dd-primary-light: #3b82f6;  /* Bright Blue - Active states */
        --dd-primary-dark: #1e3a8a;    /* Navy - Headers */
        
        /* Secondary Accent Colors */
        --dd-teal: #0d9488;           /* Public Services */
        --dd-emerald: #059669;        /* Agriculture */
        --dd-amber: #d97706;          /* Alerts/Warnings */
        --dd-rose: #e11d48;           /* Health/Emergency */
        --dd-violet: #7c3aed;         /* Jobs/Opportunities */
        
        /* Neutral Palette */
        --dd-dark: #0f172a;           /* Near Black - Text */
        --dd-gray-800: #1e293b;       /* Dark Gray */
        --dd-gray-600: #475569;       /* Medium Gray - Body text */
        --dd-gray-400: #94a3b8;       /* Light Gray - Muted text */
        --dd-gray-200: #e2e8f0;       /* Borders */
        --dd-gray-100: #f1f5f9;       /* Light backgrounds */
        --dd-white: #ffffff;
        
        /* Semantic Colors */
        --dd-water: #0ea5e9;          /* Water - Sky Blue */
        --dd-health: #f43f5e;         /* Health - Rose */
        --dd-agriculture: #10b981;    /* Agriculture - Emerald */
        --dd-employment: #8b5cf6;     /* Employment - Violet */
        
        /* Shadows & Effects */
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
        
        /* Border Radius */
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --radius-xl: 24px;
        --radius-full: 9999px;
    }

    /* Hero Section with Background Image */
    .hero-section {
        position: relative;
        background: linear-gradient(135deg, rgba(30, 64, 175, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%),
                    url('/images/smart_banner.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        border-radius: var(--radius-lg);
        padding: 6rem 2rem;
        margin-bottom: 2rem;
        overflow: hidden;
        box-shadow: var(--shadow-xl);
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 0.5rem 1rem;
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: white;
        margin-bottom: 1.5rem;
    }

    .hero-badge .pulse {
        width: 8px;
        height: 8px;
        background: #22c55e;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.2); }
    }

    .hero-title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        color: white;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .hero-subtitle {
        font-size: 1.125rem;
        color: rgba(255, 255, 255, 0.85);
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.7;
    }

    /* Statistics Overview Bar */
    .stats-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 800;
        color: white;
        display: block;
    }

    .stat-label {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Search Container */
    .search-wrapper {
        max-width: 700px;
        margin: -2rem auto 3rem;
        position: relative;
        z-index: 10;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: white;
        border-radius: var(--radius-full);
        padding: 0.75rem 1rem;
        box-shadow: var(--shadow-xl);
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }

    .search-box:focus-within {
        border-color: var(--dd-primary-light);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15), var(--shadow-xl);
    }

    .search-icon {
        font-size: 1.25rem;
        margin-right: 0.75rem;
        color: var(--dd-gray-400);
    }

    .search-input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 1rem;
        color: var(--dd-dark);
        outline: none;
    }

    .search-input::placeholder {
        color: var(--dd-gray-400);
    }

    .search-shortcut {
        display: none;
        background: var(--dd-gray-100);
        padding: 0.25rem 0.5rem;
        border-radius: var(--radius-sm);
        font-size: 0.75rem;
        color: var(--dd-gray-600);
        font-family: monospace;
    }

    @@media (min-width: 768px) {
        .search-shortcut { display: block; }
    }

    /* Professional Dashboard Footer */
    .dashboard-footer {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(20px);
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        margin-top: 4rem;
        padding: 4rem 0 2rem;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 3rem;
        margin-bottom: 3rem;
    }

    .footer-column h4 {
        color: var(--dd-dark);
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-links li {
        margin-bottom: 0.75rem;
    }

    .footer-links a {
        color: var(--dd-gray-600);
        text-decoration: none;
        font-size: 0.9375rem;
        transition: color 0.2s;
    }

    .footer-links a:hover {
        color: var(--dd-primary);
    }

    .help-card {
        background: var(--dd-gray-100);
        padding: 1.5rem;
        border-radius: var(--radius-md);
        border: 1px dashed var(--dd-gray-400);
    }

    .help-card h5 {
        font-size: 0.9375rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .help-card p {
        font-size: 0.8125rem;
        color: var(--dd-gray-600);
        margin-bottom: 1rem;
    }

    /* Section Styling */
    .dashboard-section {
        margin-bottom: 3rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--dd-dark);
    }

    .section-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        font-size: 1.25rem;
    }

    .section-icon.water { background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); }
    .section-icon.health { background: linear-gradient(135deg, #ffe4e6 0%, #fecdd3 100%); }
    .section-icon.agriculture { background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%); }
    .section-icon.employment { background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%); }

    .view-all-link {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--dd-primary);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        transition: gap 0.2s ease;
    }

    .view-all-link:hover {
        gap: 0.5rem;
        color: var(--dd-primary-dark);
    }

    /* Card Component Styles - Glassmorphism Edition */
    .dd-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px) saturate(180%);
        -webkit-backdrop-filter: blur(12px) saturate(180%);
        border-radius: var(--radius-md);
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .dd-card:hover {
        background: rgba(255, 255, 255, 0.85);
        box-shadow: var(--shadow-lg);
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.5);
    }

    .dd-card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--dd-gray-100);
    }

    .dd-card-body {
        padding: 1.25rem;
    }

    .dd-card-footer {
        padding: 1rem 1.25rem;
        background: var(--dd-gray-100);
        border-top: 1px solid var(--dd-gray-200);
    }

    /* Status Badges */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.025em;
    }

    .status-badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .status-badge.active {
        background: #dcfce7;
        color: #166534;
    }
    .status-badge.active::before { background: #22c55e; }

    .status-badge.scheduled {
        background: #dbeafe;
        color: #1e40af;
    }
    .status-badge.scheduled::before { background: #3b82f6; }

    .status-badge.delayed {
        background: #fef3c7;
        color: #92400e;
    }
    .status-badge.delayed::before { background: #f59e0b; }

    .status-badge.critical {
        background: #fee2e2;
        color: #991b1b;
    }
    .status-badge.critical::before { background: #ef4444; }

    .status-badge.available {
        background: #dcfce7;
        color: #166534;
    }
    .status-badge.available::before { background: #22c55e; }

    .status-badge.low {
        background: #fee2e2;
        color: #991b1b;
    }
    .status-badge.low::before { background: #ef4444; }

    /* Feature Cards - Water Distribution */
    .water-card {
        border-left: 4px solid var(--dd-water);
    }

    .water-card .location-name {
        font-weight: 700;
        color: var(--dd-dark);
        font-size: 1.0625rem;
    }

    .water-card .schedule-time {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--dd-gray-600);
        margin-top: 0.5rem;
    }

    .water-card .schedule-note {
        margin-top: 0.75rem;
        padding: 0.625rem 0.875rem;
        background: #fffbeb;
        border-radius: var(--radius-sm);
        font-size: 0.8125rem;
        color: #92400e;
        border-left: 3px solid #f59e0b;
    }

    /* Clinic Cards */
    .clinic-card {
        border-left: 4px solid var(--dd-health);
    }

    .clinic-name {
        font-weight: 700;
        color: var(--dd-dark);
        margin-bottom: 0.5rem;
    }

    .clinic-meta {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
        font-size: 0.875rem;
        color: var(--dd-gray-600);
    }

    .emergency-line {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-weight: 600;
        color: var(--dd-rose);
        margin-top: 0.5rem;
    }

    .medicine-status {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
    }

    .last-updated {
        font-size: 0.6875rem;
        color: var(--dd-gray-400);
    }

    /* Market List Items */
    .market-list {
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .market-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        background: white;
        border-bottom: 1px solid var(--dd-gray-100);
        transition: background 0.2s ease;
    }

    .market-item:hover {
        background: var(--dd-gray-100);
    }

    .market-item:last-child {
        border-bottom: none;
    }

    .crop-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .crop-icon {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-sm);
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }

    .crop-details .crop-name {
        font-weight: 600;
        color: var(--dd-dark);
    }

    .crop-details .market-location {
        font-size: 0.8125rem;
        color: var(--dd-gray-600);
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .disease-alert {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        background: #fee2e2;
        color: #991b1b;
        padding: 0.125rem 0.5rem;
        border-radius: var(--radius-sm);
        font-size: 0.6875rem;
        font-weight: 600;
        margin-left: 0.5rem;
    }

    .price-tag {
        text-align: right;
    }

    .price-value {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--dd-emerald);
    }

    .price-unit {
        font-size: 0.75rem;
        color: var(--dd-gray-400);
    }

    /* Job Posting Cards */
    .job-item {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1.25rem;
        background: white;
        border-bottom: 1px solid var(--dd-gray-100);
        transition: background 0.2s ease;
    }

    .job-item:hover {
        background: var(--dd-gray-100);
    }

    .job-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .job-title {
        font-weight: 700;
        color: var(--dd-dark);
        font-size: 1rem;
    }

    .job-posted {
        font-size: 0.75rem;
        color: var(--dd-gray-400);
        white-space: nowrap;
    }

    .job-company {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.875rem;
        color: var(--dd-gray-600);
    }

    .job-type {
        display: inline-flex;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-full);
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.025em;
    }

    .job-type.fulltime {
        background: #ede9fe;
        color: #5b21b6;
    }

    .job-type.training {
        background: #fef3c7;
        color: #92400e;
    }

    /* Empty States */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        color: var(--dd-gray-400);
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    /* Filter Animation */
    .filterable-item {
        transition: all 0.3s ease;
    }

    .filterable-item.hidden {
        display: none;
    }

    /* Quick Links Bar - Horizontal Scrollable */
    .quick-links-container {
        position: relative;
        margin-bottom: 2rem;
    }

    .quick-links {
        display: flex;
        gap: 0.75rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(8px);
        border-radius: var(--radius-md);
        border: 1px solid rgba(255, 255, 255, 0.2);
        overflow-x: auto;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
        scrollbar-color: var(--dd-gray-400) transparent;
    }

    .quick-links::-webkit-scrollbar {
        height: 6px;
    }

    .quick-links::-webkit-scrollbar-track {
        background: transparent;
        border-radius: var(--radius-full);
    }

    .quick-links::-webkit-scrollbar-thumb {
        background: var(--dd-gray-400);
        border-radius: var(--radius-full);
    }

    .quick-links::-webkit-scrollbar-thumb:hover {
        background: var(--dd-gray-600);
    }

    .quick-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        background: white;
        border: 1px solid var(--dd-gray-200);
        border-radius: var(--radius-full);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--dd-gray-700);
        text-decoration: none;
        transition: all 0.2s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .quick-link:hover {
        border-color: var(--dd-primary-light);
        color: var(--dd-primary);
        box-shadow: var(--shadow-sm);
        transform: translateY(-1px);
    }

    .quick-link-icon {
        font-size: 1.125rem;
    }

    .scroll-indicator {
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        background: linear-gradient(90deg, transparent, var(--dd-gray-100));
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        opacity: 0.8;
        border-radius: 50%;
    }

    /* Notification System */
    .notification-container {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 350px;
    }

    .notification {
        background: white;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-xl);
        padding: 1rem 1.25rem;
        border-left: 4px solid var(--dd-primary);
        animation: slideInRight 0.3s ease, fadeOut 0.3s ease 4.7s;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        position: relative;
        overflow: hidden;
    }

    .notification::before {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        height: 3px;
        background: var(--dd-primary);
        animation: progress 5s linear;
    }

    @@keyframes progress {
        from { width: 100%; }
        to { width: 0%; }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes fadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
    }

    .notification-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .notification-icon.water { background: #dbeafe; }
    .notification-icon.health { background: #ffe4e6; }
    .notification-icon.agriculture { background: #d1fae5; }
    .notification-icon.jobs { background: #ede9fe; }
    .notification-icon.system { background: var(--dd-gray-100); }

    .notification-content {
        flex: 1;
    }

    .notification-title {
        font-weight: 600;
        color: var(--dd-dark);
        font-size: 0.9375rem;
        margin-bottom: 0.25rem;
    }

    .notification-message {
        font-size: 0.8125rem;
        color: var(--dd-gray-600);
        line-height: 1.4;
    }

    .notification-close {
        background: none;
        border: none;
        color: var(--dd-gray-400);
        cursor: pointer;
        padding: 0;
        font-size: 1.25rem;
        line-height: 1;
        transition: color 0.2s;
    }

    .notification-close:hover {
        color: var(--dd-gray-600);
    }

    /* Full Page Background - Fixed & Immersive */
    .dashboard-background {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            linear-gradient(135deg, rgba(30, 64, 175, 0.4) 0%, rgba(15, 23, 42, 0.6) 100%),
            url('/images/smart_banner.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        z-index: -10;
        pointer-events: none;
    }

    .dashboard-background::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--dd-gray-100);
        opacity: 0.85;
    }

    /* Responsive Grid */
    @@media (max-width: 991px) {
        .hero-section {
            padding: 3rem 1.5rem;
        }
        
        .stats-bar {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 575px) {
        .stats-bar {
            grid-template-columns: 1fr;
        }
        
        .market-item {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.75rem;
        }
        
        .price-tag {
            text-align: left;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
    }
</style>

