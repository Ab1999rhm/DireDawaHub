@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<DireDawaHub.SharedResource> localizer
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dire Dawa Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* ============================================
           DIRE DAWA HUB - LAYOUT STYLES
           Consistent with Dashboard Design System
           ============================================ */
        
        :root {
            --dd-primary: #1e40af;
            --dd-primary-light: #3b82f6;
            --dd-primary-dark: #1e3a8a;
            --dd-gray-100: #f1f5f9;
            --dd-gray-200: #e2e8f0;
            --dd-gray-400: #94a3b8;
            --dd-gray-600: #475569;
            --dd-gray-800: #1e293b;
            --dd-dark: #0f172a;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            --radius-sm: 8px;
            --radius-md: 12px;
        }
        
        body { 
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; 
            margin: 0; 
            background-color: var(--dd-gray-100);
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(30, 64, 175, 0.03) 0%, transparent 20%),
                radial-gradient(circle at 90% 80%, rgba(13, 148, 136, 0.03) 0%, transparent 20%);
            background-attachment: fixed;
        }
        
        /* Contributor Layout CSS */
        .wrapper { display: flex; height: 100vh; overflow: hidden; }
        
        .sidebar { 
            width: 280px; 
            background: linear-gradient(180deg, var(--dd-dark) 0%, var(--dd-gray-800) 100%);
            color: #ffffff; 
            display: flex; 
            flex-direction: column; 
            z-index: 10;
            box-shadow: 4px 0 15px rgba(0,0,0,0.1);
        }
        
        .sidebar-header { 
            padding: 20px;
            font-size: 1.3rem;
            font-weight: 700;
            color: #ffffff;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
            letter-spacing: 0.5px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .sidebar-collapse-btn {
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: #ffffff;
            width: 32px;
            height: 32px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .sidebar-collapse-btn:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .sidebar.collapsed {
            width: 60px;
            min-width: 60px;
        }

        .sidebar.collapsed .sidebar-header span,
        .sidebar.collapsed .sidebar-nav .sidebar-header,
        .sidebar.collapsed .sidebar-bottom .user-name,
        .sidebar.collapsed .sidebar-bottom .btn span {
            display: none;
        }

        .sidebar.collapsed .sidebar-nav .nav-item a {
            font-size: 0 !important;
            justify-content: center;
            padding: 14px 0 !important;
        }

        .sidebar.collapsed .sidebar-header {
            padding: 20px 10px;
            flex-direction: column;
            gap: 10px;
            justify-content: center;
        }

        .sidebar.collapsed .sidebar-lang-dropdown {
            margin: 0 !important;
        }

        .sidebar.collapsed .sidebar-lang-dropdown .btn span,
        .sidebar.collapsed .sidebar-lang-dropdown .btn::after {
            display: none;
        }

        .sidebar.collapsed .sidebar-lang-dropdown .btn {
            padding: 8px;
            width: 38px;
            height: 38px;
            justify-content: center;
        }

        .sidebar.collapsed .sidebar-collapse-btn {
            width: 28px;
            height: 28px;
        }

        .sidebar.collapsed .sidebar-collapse-btn i {
            transform: rotate(180deg);
        }

        .sidebar.collapsed .sidebar-nav .nav-item {
            text-align: center;
        }

        .sidebar.collapsed .sidebar-nav .nav-item a::before {
            font-size: 1.5rem;
            display: block;
        }

        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Admin"]::before { content: "🛡️"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="ManageUsers"]::before { content: "👥"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Catalog"]::before { content: "📁"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="AuditLogs"]::before { content: "📜"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Contributor"]::before { content: "👩‍💻"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Water"]::before { content: "💧"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Health"]::before { content: "🏥"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Jobs"]::before { content: "💼"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Agriculture"]::before { content: "🌾"; }
        .sidebar.collapsed .sidebar-nav .nav-item a[href="/"]::before,
        .sidebar.collapsed .sidebar-nav .nav-item a[href*="Home"]::before { content: "🌍"; }

        .sidebar.collapsed .sidebar-bottom {
            padding: 10px;
        }

        .sidebar.collapsed .sidebar-bottom .user-info {
            justify-content: center;
        }

        .sidebar.collapsed .sidebar-lang-options {
            display: none !important;
        }

        .sidebar.collapsed .sidebar-lang-icon {
            margin-right: 0 !important;
            font-size: 1.2rem;
        }

        .sidebar.collapsed .sidebar-bottom .btn {
            padding: 8px;
        }

        .sidebar.collapsed + .main-content {
            margin-left: 60px;
        }

        .sidebar-bottom {
            margin-top: auto;
            padding: 15px 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: white;
            font-size: 14px;
        }

        .user-name {
            font-size: 0.875rem;
            color: #e2e8f0;
            font-weight: 500;
        }

        .sidebar {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.9) 0%, rgba(30, 64, 175, 0.8) 100%),
                        url('/images/smart_banner.png');
            background-size: cover;
            background-position: left center;
        }
        
        .sidebar-nav { 
            flex-grow: 1; 
            padding-top: 16px; 
        }
        
        .nav-link.custom-nav { 
            color: var(--dd-gray-400); 
            padding: 14px 24px; 
            font-weight: 500; 
            font-size: 0.9375rem; 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
            margin: 2px 0;
        }
        
        .nav-link.custom-nav:hover { 
            color: #ffffff; 
            background: rgba(255, 255, 255, 0.05); 
            border-left-color: var(--dd-primary-light);
        }
        
        .nav-link.custom-nav.active {
            color: #ffffff;
            background: rgba(59, 130, 246, 0.15);
            border-left-color: var(--dd-primary-light);
        }
        
        .main-content { 
            flex-grow: 1; 
            overflow-y: auto; 
            display: flex; 
            flex-direction: column; 
        }
        
        .topbar { 
            background: #ffffff; 
            height: 70px; 
            padding: 0 30px; 
            box-shadow: var(--shadow-sm); 
            display: flex; 
            align-items: center; 
            justify-content: flex-end; 
            border-bottom: 1px solid var(--dd-gray-200);
        }
        
        .content-area { 
            padding: 30px; 
            flex-grow: 1; 
        }

        /* Public Layout CSS */
        .public-navbar { 
            background: linear-gradient(135deg, var(--dd-primary) 0%, var(--dd-primary-dark) 100%);
            box-shadow: var(--shadow-md); 
            padding: 16px 0; 
        }
        
        .public-navbar .navbar-brand {
            color: white !important;
            font-weight: 800;
            letter-spacing: -0.02em;
        }
        
        .public-navbar .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500;
        }
        
        .public-navbar .nav-link:hover {
            color: white !important;
        }
        
        .auth-btn { 
            background-color: rgba(255, 255, 255, 0.1);
            color: #ffffff; 
            border: 2px solid rgba(255, 255, 255, 0.3); 
            padding: 10px 22px; 
            border-radius: var(--radius-sm); 
            font-weight: 600; 
            text-decoration: none; 
            transition: all 0.2s ease;
            backdrop-filter: blur(10px);
        }
        
        .auth-btn:hover { 
            background-color: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.5);
            transform: translateY(-1px);
        }
        
        /* Language Selector */
        .lang-selector a {
            transition: all 0.2s ease;
            padding: 4px 8px;
            border-radius: 4px;
        }
        
        .lang-selector a:hover {
            background: rgba(255, 255, 255, 0.1);
        }
        
        .lang-selector a.text-primary {
            background: rgba(255, 255, 255, 0.2) !important;
            font-weight: 600;
        }
        
        /* Footer */
        .public-footer {
            background: white;
            border-top: 1px solid var(--dd-gray-200);
            padding: 1.5rem 0;
        }
        
        .public-footer p {
            color: var(--dd-gray-600);
            font-size: 0.875rem;
        }
        
        /* Scrollbar for sidebar */
        .sidebar-nav::-webkit-scrollbar {
            width: 6px;
        }
        
        .sidebar-nav::-webkit-scrollbar-track {
            background: transparent;
        }
        
        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 3px;
        }

        /* ============================================
           TOAST NOTIFICATION STYLES
           ============================================ */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 400px;
        }

        .toast {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            animation: toastSlideIn 0.3s ease;
            max-width: 100%;
        }

        .toast.toast-success { border-left: 4px solid #10b981; }
        .toast.toast-error { border-left: 4px solid #ef4444; }
        .toast.toast-warning { border-left: 4px solid #f59e0b; }
        .toast.toast-info { border-left: 4px solid #3b82f6; }

        .toast-icon {
            font-size: 20px;
            flex-shrink: 0;
        }

        .toast-content {
            flex: 1;
            min-width: 0;
        }

        .toast-title {
            font-weight: 600;
            color: #f8fafc;
            font-size: 14px;
            margin-bottom: 4px;
        }

        .toast-message {
            color: #94a3b8;
            font-size: 13px;
            line-height: 1.5;
        }

        .toast-close {
            background: none;
            border: none;
            color: #64748b;
            cursor: pointer;
            padding: 4px;
            font-size: 16px;
            line-height: 1;
            transition: color 0.2s;
        }

        .toast-close:hover {
            color: #f8fafc;
        }

        .toast-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 0 0 0 12px;
            animation: toastProgress 5s linear forwards;
        }

        @@keyframes toastSlideIn {
            from {
                opacity: 0;
                transform: translateX(100%);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes toastProgress {
            from { width: 100%; }
            to { width: 0%; }
        }

        .toast-exit {
            animation: toastSlideOut 0.3s ease forwards;
        }

        @@keyframes toastSlideOut {
            from {
                opacity: 1;
                transform: translateX(0);
            }
            to {
                opacity: 0;
                transform: translateX(100%);
            }
        }

        /* Breadcrumb Navigation */
        .breadcrumb-nav {
            background: rgba(15, 23, 42, 0.5);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 12px 24px;
            font-size: 14px;
        }

        .breadcrumb-item a {
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.2s;
        }

        .breadcrumb-item a:hover {
            color: #60a5fa;
        }

        .breadcrumb-item.active {
            color: #f8fafc;
        }

        .breadcrumb-divider {
            color: #64748b;
            margin: 0 8px;
        }

        /* Mobile Responsive Tables */
        @@media (max-width: 768px) {
            .table-responsive {
                display: block;
                width: 100%;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            
            .admin-table-container {
                margin: 0 -1rem;
                border-radius: 0;
            }
            
            .search-filter-bar form .row {
                gap: 0.5rem;
            }
            
            .search-filter-bar .col-md-5,
            .search-filter-bar .col-md-3,
            .search-filter-bar .col-md-2 {
                width: 100%;
                margin-bottom: 0.5rem;
            }
            
            .pagination-container {
                flex-direction: column;
                gap: 1rem;
            }
            
            .pagination {
                flex-wrap: wrap;
                justify-content: center;
            }
        }

        /* Loading Skeleton */
        .skeleton {
            background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: 4px;
        }

        @@keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* Empty State Styles */
        .empty-state {
            text-align: center;
            padding: 3rem 2rem;
            color: #94a3b8;
        }

        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-state h4 {
            color: #f8fafc;
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            margin-bottom: 1.5rem;
        }

        .empty-state .btn {
            margin: 0.25rem;
        }

        /* Hover Cards */
        .hover-card {
            position: absolute;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 1rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            z-index: 1000;
            min-width: 250px;
            display: none;
        }

        .hover-card.show {
            display: block;
            animation: fadeIn 0.2s ease;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Filter Chips */
        .filter-chips {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

        .filter-chip {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #94a3b8;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.875rem;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .filter-chip:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #f8fafc;
        }

        .filter-chip.active {
            background: rgba(59, 130, 246, 0.2);
            border-color: #3b82f6;
            color: #60a5fa;
        }
    </style>
</head>
<body>
    @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Contributor")))
    {
        // -------------------------------------------------------------
        // MANAGER PLATFORM: Only for Verified Contributors & Admins
        // -------------------------------------------------------------
        <div class="wrapper">
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-header d-flex align-items-center justify-content-between p-3">
                    <span class="fw-bold">Dire Dawa Hub ✨</span>
                    <button class="sidebar-collapse-btn" onclick="toggleSidebar()" title="Collapse/Expand Sidebar">
                        <i class="bi bi-chevron-left" id="collapseIcon"></i>
                    </button>
                </div>
                
                <!-- NEW TOP LEVEL LANGUAGE DROPDOWN -->
                <div class="sidebar-lang-dropdown px-3 mb-2">
                    <form asp-controller="Language" asp-action="SetLanguage" method="post" id="sidebarLangForm">
                        <input type="hidden" id="sidebarCulture" name="culture" value="" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <div class="dropdown">
                            <button class="btn btn-outline-light btn-sm dropdown-toggle w-100 d-flex align-items-center justify-content-between border-0 bg-white bg-opacity-10" 
                                    type="button" id="sidebarLangDrop" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 8px;">
                                <div class="d-flex align-items-center">
                                    <span class="me-2">🌐</span>
                                    <span>@localizer["Language"]</span>
                                </div>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark shadow border-0" aria-labelledby="sidebarLangDrop" style="background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(10px);">
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="document.getElementById('sidebarCulture').value='en'; document.getElementById('sidebarLangForm').submit();">English</a></li>
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="document.getElementById('sidebarCulture').value='am'; document.getElementById('sidebarLangForm').submit();">አማርኛ</a></li>
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="document.getElementById('sidebarCulture').value='om'; document.getElementById('sidebarLangForm').submit();">Afaan Oromoo</a></li>
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="document.getElementById('sidebarCulture').value='so'; document.getElementById('sidebarLangForm').submit();">Af Somali</a></li>
                            </ul>
                        </div>
                    </form>
                </div>

                <div class="sidebar-nav">
                    <ul class="nav flex-column">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="sidebar-header" style="font-size: 0.8rem; padding: 10px 20px; color: #94a3b8; border: none; letter-spacing: 1px;">@localizer["ADMINISTRATOR"]</li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav fw-bold @(Context.Request.Path.StartsWithSegments("/Admin") && !Context.Request.Path.StartsWithSegments("/Admin/ManageUsers") && !Context.Request.Path.StartsWithSegments("/Admin/AuditLogs") && !Context.Request.Path.StartsWithSegments("/Admin/Catalog") ? "active" : "")" 
                                   asp-area="" asp-controller="Admin" asp-action="Index" style="color: #93c5fd;">🛡️ @localizer["System Analytics"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Admin/ManageUsers") ? "active" : "")" 
                                   asp-area="" asp-controller="Admin" asp-action="ManageUsers">👥 @localizer["Identity Registry"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Admin/Catalog") ? "active" : "")" 
                                   asp-area="" asp-controller="Admin" asp-action="Catalog">📁 @localizer["System Catalog"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Admin/AuditLogs") ? "active" : "")" 
                                   asp-area="" asp-controller="Admin" asp-action="AuditLogs">📜 @localizer["Audit Logs"]</a>
                            </li>
                        }

                        @if (User.IsInRole("Contributor")) 
                        {
                            <li class="sidebar-header" style="font-size: 0.8rem; padding: 10px 20px; color: #94a3b8; border: none; letter-spacing: 1px;">@localizer["DATA WORKSPACE"]</li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Contributor") ? "active" : "")" 
                                   asp-area="" asp-controller="Contributor" asp-action="Index">👩‍💻 @localizer["My Dashboard"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Water") ? "active" : "")" 
                                   asp-area="" asp-controller="Water" asp-action="Index">💧 Water Tracker</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Health") ? "active" : "")" 
                                   asp-area="" asp-controller="Health" asp-action="Index">🏥 Health Directory</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Jobs") ? "active" : "")" 
                                   asp-area="" asp-controller="Jobs" asp-action="Index">💼 Job Board</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link custom-nav @(Context.Request.Path.StartsWithSegments("/Agriculture") ? "active" : "")" 
                                   asp-area="" asp-controller="Agriculture" asp-action="Index">🌾 Agriculture</a>
                            </li>
                        }
                        
                        <li><hr class="dropdown-divider opacity-25 mx-3 my-2" style="border-color: white;" /></li>
                        
                        <li class="nav-item">
                            <a class="nav-link custom-nav @(Context.Request.Path == "/" || Context.Request.Path == "/Home/Index" ? "active" : "")" 
                               asp-area="" asp-controller="Home" asp-action="Index">🌍 @localizer["View Public Site"]</a>
                        </li>
                    </ul>
                </div>
                
                <!-- Bottom Section: User Account & Logout -->
                <div class="sidebar-bottom">
                    <div class="user-info">
                        <div class="user-avatar">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                        <span class="user-name">@User.Identity?.Name</span>
                    </div>
                    
                    <a class="btn btn-outline-danger btn-sm fw-bold px-3 py-2 w-100" style="border-radius: 6px;" asp-area="" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i> <span>Logout</span>
                    </a>
                </div>
            </aside>
            <main class="main-content" id="mainContent">
                <div class="content-area">@RenderBody()</div>
            </main>
        </div>
    }
    else
    {
        // -------------------------------------------------------------
        // CIVILIAN PLATFORM: Pure Read-Only Digital Notice Board
        // -------------------------------------------------------------
        <nav class="public-navbar sticky-top">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="navbar-brand fw-bold mb-0 h1 text-decoration-none" href="/" style="color: #111827; font-size: 1.4rem;">
                    🌍 Dire Dawa Hub
                </a>
                <div class="d-flex align-items-center gap-3">
                    <div class="lang-selector d-none d-md-flex align-items-center text-white-50 fw-bold me-2" style="font-size: 13px; gap:8px;">
                        <span style="font-size: 1.1rem; margin-right: 4px;">🌐</span>
                        <form asp-controller="Language" asp-action="SetLanguage" method="post" id="langForm" style="margin: 0; display: flex; align-items: center; gap: 6px;">
                            <input type="hidden" id="langCulture" name="culture" value="" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <a href="javascript:void(0)" class="text-decoration-none @(Context.Request.Cookies[".AspNetCore.Culture"]?.Contains("en") == true ? "text-primary" : "text-white-50")" onclick="document.getElementById('langCulture').value='en'; document.getElementById('langForm').submit();">EN</a>
                            <span class="text-white-25">|</span>
                            <a href="javascript:void(0)" class="text-decoration-none @(Context.Request.Cookies[".AspNetCore.Culture"]?.Contains("am") == true ? "text-primary" : "text-white-50")" onclick="document.getElementById('langCulture').value='am'; document.getElementById('langForm').submit();">አማ</a>
                            <span class="text-white-25">|</span>
                            <a href="javascript:void(0)" class="text-decoration-none @(Context.Request.Cookies[".AspNetCore.Culture"]?.Contains("om") == true ? "text-primary" : "text-white-50")" onclick="document.getElementById('langCulture').value='om'; document.getElementById('langForm').submit();">Oro</a>
                            <span class="text-white-25">|</span>
                            <a href="javascript:void(0)" class="text-decoration-none @(Context.Request.Cookies[".AspNetCore.Culture"]?.Contains("so") == true ? "text-primary" : "text-white-50")" onclick="document.getElementById('langCulture').value='so'; document.getElementById('langForm').submit();">So</a>
                        </form>
                    </div>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge bg-warning text-dark px-3 py-2 border border-warning shadow-sm" style="border-radius: 6px; font-size: 0.85rem;"><i class="bi bi-hourglass-split"></i> Pending Security Approval</span>
                            <a class="auth-btn" asp-area="" asp-controller="Account" asp-action="Logout">Logout</a>
                        </div>
                    }
                    else
                    {
                        <a class="auth-btn" asp-area="" asp-controller="Account" asp-action="Login">Contributors Portal</a>
                    }
                </div>
            </div>
        </nav>
        
        <div class="container my-5">
            @RenderBody()
        </div>
        
        <footer class="public-footer text-center">
            <div class="container">
                <p class="mb-0 fw-medium">© 2026 Dire Dawa Community Resource Hub. Community driven data.</p>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Toast Notification Container -->
    <div id="toast-container" class="toast-container"></div>
    
    <div id="signalr-notifications" class="notification-container"></div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const notificationContainer = document.getElementById("signalr-notifications");
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveWaterAlert", function (location, status, notes) {
            // Determine if the alert is inherently dangerous
            const isDanger = status.toLowerCase().includes('delay') || status.toLowerCase().includes('critical') || status.toLowerCase().includes('stop');
            
            const notif = document.createElement("div");
            notif.className = "notification shadow-lg";
            if (isDanger) notif.style.borderLeftColor = "#ef4444";
            
            notif.innerHTML = `
                <div class="notification-icon water" style="font-size:1.5rem">💧</div>
                <div class="notification-content">
                    <div class="notification-title" style="color: ${isDanger ? '#ef4444' : '#0284c7'}">LIVE UPDATE: ${location}</div>
                    <div class="notification-message">
                        <strong>${status}</strong> - ${notes}
                    </div>
                </div>
            `;
            
            // Pop up globally on all screens!
            notificationContainer.appendChild(notif);
            
            setTimeout(() => {
                notif.remove();
            }, 6000); 
        });

        connection.start().catch(function(err) {
            console.error("SignalR: " + err.toString());
        });

        // Sidebar Toggle Function
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            const collapseIcon = document.getElementById('collapseIcon');
            
            sidebar.classList.toggle('collapsed');
            
            // Store preference in localStorage
            const isCollapsed = sidebar.classList.contains('collapsed');
            localStorage.setItem('sidebarCollapsed', isCollapsed);
        }

        // Restore sidebar state on page load
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            
            if (isCollapsed && sidebar) {
                sidebar.classList.add('collapsed');
            }
        });

        // Toast Notification Functions
        function showToast(title, message, type = 'info', duration = 5000) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            
            const icons = {
                success: '✅',
                error: '❌',
                warning: '⚠️',
                info: 'ℹ️'
            };
            
            toast.innerHTML = `
                <div class="toast-icon">${icons[type]}</div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-message">${message}</div>
                </div>
                <button class="toast-close" onclick="this.parentElement.remove()">×</button>
                <div class="toast-progress"></div>
            `;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.classList.add('toast-exit');
                setTimeout(() => toast.remove(), 300);
            }, duration);
        }

        // Show TempData messages as toasts
        @if (TempData["Success"] != null)
        {
            <text>showToast('Success', '@TempData["Success"]', 'success');</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>showToast('Error', '@TempData["Error"]', 'error');</text>
        }
        @if (TempData["Warning"] != null)
        {
            <text>showToast('Warning', '@TempData["Warning"]', 'warning');</text>
        }

        // Keyboard Shortcuts
        document.addEventListener('keydown', function(e) {
            // / key to focus search
            if (e.key === '/' && !e.ctrlKey && !e.altKey && !e.metaKey) {
                const searchInput = document.querySelector('input[name="searchTerm"]');
                if (searchInput && document.activeElement !== searchInput) {
                    e.preventDefault();
                    searchInput.focus();
                }
            }
            
            // Escape to clear selection
            if (e.key === 'Escape') {
                const checkboxes = document.querySelectorAll('.user-select-checkbox:checked');
                checkboxes.forEach(cb => cb.checked = false);
                updateBulkActions();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
