@model IEnumerable<DireDawaHub.Models.CommunityPoster>
@{
    ViewData["Title"] = "My Posters & Blogs";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1">🖼️ My Posters & Blogs</h2>
            <p class="text-muted mb-0">Manage your published content on the community dashboard.</p>
        </div>
        <a asp-action="CreatePoster" class="btn btn-primary rounded-pill px-4 fw-bold">
            <i class="bi bi-plus-lg"></i> CREATE NEW
        </a>
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var poster in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <img src="@poster.ImagePath" class="card-img-top" style="height: 200px; object-fit: cover;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">@poster.Category</span>
                                <span class="small text-muted">@poster.PostedDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <h5 class="fw-bold mb-2">@poster.Title</h5>
                            @if (!string.IsNullOrEmpty(poster.Location))
                            {
                                <div class="small text-primary mb-1"><i class="bi bi-geo-alt"></i> @poster.Location</div>
                            }
                            <p class="small text-muted mb-4 text-truncate">@poster.Description</p>
                            
                            <div class="d-flex gap-2">
                                <form asp-action="DeletePoster" method="post" onsubmit="return confirm('Are you sure you want to delete this post?');">
                                    <input type="hidden" name="id" value="@poster.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                                <a asp-action="EditPoster" asp-route-id="@poster.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="fs-1 opacity-25 mb-3">🖼️</div>
                <h3>No posters yet</h3>
                <p class="text-muted">You haven't posted any announcements or blogs yet.</p>
                <a asp-action="CreatePoster" class="btn btn-primary rounded-pill px-4 mt-3">Start Posting</a>
            </div>
        }
    </div>
</div>
