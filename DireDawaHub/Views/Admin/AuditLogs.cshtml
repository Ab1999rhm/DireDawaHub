@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<DireDawaHub.SharedResource> localizer
@model IEnumerable<DireDawaHub.Models.SecurityAuditLog>
@{
    ViewData["Title"] = @localizer["Audit Logs"];
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 admin-header-anim">
        <div>
            <h1 class="fw-bold mb-0">📜 @localizer["Security Audit Logs"]</h1>
            <p class="text-muted">@localizer["Complete record of all administrative actions and system events"]</p>
        </div>
        <div class="text-end">
            <a href="@Url.Action("ExportAuditLogsToCsv")" class="admin-btn admin-btn-outline">
                <i class="bi bi-filetype-csv me-1"></i> @localizer["Export CSV"]
            </a>
        </div>
    </div>
    <div class="row g-4 mb-4 admin-header-anim" style="animation-delay: 0.1s;">
        <div class="col-md-3">
            <div class="admin-card text-center">
                <div class="fs-4 fw-bold">@Model.Count()</div>
                <div class="text-muted x-small text-uppercase">@localizer["Total Events"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center">
                <div class="fs-4 fw-bold text-info">@Model.Count(l => l.Severity == AuditSeverity.Info)</div>
                <div class="text-muted x-small text-uppercase">@localizer["Info Events"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center">
                <div class="fs-4 fw-bold text-warning">@Model.Count(l => l.Severity == AuditSeverity.Warning)</div>
                <div class="text-muted x-small text-uppercase">@localizer["Warnings"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center">
                <div class="fs-4 fw-bold text-danger">@Model.Count(l => l.Severity == AuditSeverity.Critical)</div>
                <div class="text-muted x-small text-uppercase">@localizer["Critical"]</div>
            </div>
        </div>
    </div>

    <div class="admin-table-wrapper admin-header-anim" style="animation-delay: 0.2s;">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>@localizer["Timestamp"]</th>
                            <th>@localizer["Action"]</th>
                            <th>@localizer["Description"]</th>
                            <th>@localizer["Performed By"]</th>
                            <th>@localizer["Target"]</th>
                            <th>@localizer["Severity"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var today = DateTime.Today;
                            var yesterday = today.AddDays(-1);
                            var thisWeekStart = today.AddDays(-(int)today.DayOfWeek);
                            
                            var groupedLogs = Model.GroupBy(log =>
                            {
                                var logDate = log.Timestamp.Date;
                                if (logDate == today) return "Today";
                                if (logDate == yesterday) return "Yesterday";
                                if (logDate >= thisWeekStart) return "This Week";
                                if (logDate >= today.AddDays(-30)) return "This Month";
                                return "Older";
                            }).OrderByDescending(g => g.Key == "Today" ? 4 : g.Key == "Yesterday" ? 3 : g.Key == "This Week" ? 2 : g.Key == "This Month" ? 1 : 0);
                            
                            foreach (var group in groupedLogs)
                            {
                                <tr class="time-group-header">
                                    <td colspan="6" class="py-2 bg-transparent">
                                        <span class="admin-badge admin-badge-neutral d-inline-flex align-items-center gap-2">
                                            @(group.Key == "Today" ? "📅" : group.Key == "Yesterday" ? "📆" : group.Key == "This Week" ? "📊" : group.Key == "This Month" ? "📈" : "📁") 
                                            @group.Key
                                            <span class="text-white-50 ms-1">(@group.Count() @localizer["events"])</span>
                                        </span>
                                    </td>
                                </tr>
                                
                                foreach (var log in group.OrderByDescending(l => l.Timestamp))
                                {
                                    <tr>
                                        <td class="ps-4 small font-monospace text-muted">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        <td>
                                            <span class="admin-badge admin-badge-neutral">@log.Action</span>
                                        </td>
                                        <td class="small text-muted" title="@log.Description">@log.Description</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2 small text-white">
                                                <div class="admin-avatar-sm" style="width: 24px; height: 24px; font-size: 10px;">
                                                    @(string.IsNullOrEmpty(log.PerformedBy) ? "?" : log.PerformedBy.Substring(0, 1).ToUpper())
                                                </div>
                                                <span>@(log.PerformedBy ?? "System")</span>
                                            </div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(log.TargetUserId))
                                            {
                                                <span class="admin-badge admin-badge-neutral">User: @log.TargetUserId.Substring(0, 8)...</span>
                                            }
                                            else if (!string.IsNullOrEmpty(log.TargetEntityType))
                                            {
                                                <span class="admin-badge admin-badge-info">@log.TargetEntityType #@log.TargetEntityId</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @switch (log.Severity)
                                            {
                                                case AuditSeverity.Info:
                                                    <span class="admin-badge admin-badge-info">ℹ️ @localizer["Info"]</span>
                                                    break;
                                                case AuditSeverity.Warning:
                                                    <span class="admin-badge admin-badge-warning">⚠️ @localizer["Warning"]</span>
                                                    break;
                                                case AuditSeverity.Critical:
                                                    <span class="admin-badge admin-badge-danger">🚨 @localizer["Critical"]</span>
                                                    break;
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination -->
            @if (ViewBag.TotalPages > 1)
            {
                <div class="pagination-container">
                    <div class="results-info">
                        @localizer["Showing"] @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) - @(Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalLogs)) 
                        @localizer["of"] @ViewBag.TotalLogs @localizer["events"]
                    </div>
                    <nav aria-label="Page navigation">
                        <ul class="pagination">
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("AuditLogs", new { page = 1, pageSize = ViewBag.PageSize })">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("AuditLogs", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            
                            @{
                                int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                            }
                            
                            @if (startPage > 1)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("AuditLogs", new { page = i, pageSize = ViewBag.PageSize })">@i</a>
                                </li>
                            }
                            
                            @if (endPage < ViewBag.TotalPages)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            
                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("AuditLogs", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("AuditLogs", new { page = ViewBag.TotalPages, pageSize = ViewBag.PageSize })">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
            else
            {
                <div class="pagination-container">
                    <div class="results-info">Showing @Model.Count() of @ViewBag.TotalLogs events</div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <h4 class="empty-state-icon">�</h4>
                <p>@localizer["No audit logs available. Actions will be logged here."]</p>
                <a href="@Url.Action("ManageUsers")" class="btn btn-outline-primary">
                    <i class="bi bi-people me-1"></i> @localizer["Manage Users"]
                </a>
                <a href="@Url.Action("Catalog")" class="btn btn-outline-info">
                    <i class="bi bi-folder me-1"></i> @localizer["View Catalog"]
                </a>
            </div>
        }
    </div>
</div>
