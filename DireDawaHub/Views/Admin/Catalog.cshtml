@model DireDawaHub.ViewModels.CatalogViewModel
@{
    ViewData["Title"] = "System Catalog Manager";
}

<style>
    :root {
        --admin-primary: #3b82f6;
        --glass-bg: rgba(15, 23, 42, 0.8);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    body {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.97) 0%, rgba(30, 64, 175, 0.95) 100%),
                    url('/images/smart_banner.png');
        background-size: cover;
        background-attachment: fixed;
        color: #f8fafc;
    }

    .catalog-card {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .table { color: #cbd5e1; }
    .table thead th { background: rgba(255, 255, 255, 0.05); color: #94a3b8; }
    .table tbody td { border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
    
    .nav-tabs { border-bottom: 1px solid var(--glass-border); }
    .nav-link { color: #94a3b8; border: none !important; }
    .nav-link.active { background: transparent !important; color: var(--admin-primary) !important; border-bottom: 2px solid var(--admin-primary) !important; }

    /* Pagination Styles */
    .pagination-container {
        background: rgba(15, 23, 42, 0.5);
        border-top: 1px solid var(--glass-border);
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .pagination {
        margin: 0;
        gap: 0.25rem;
    }

    .pagination .page-link {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #94a3b8;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .pagination .page-link:hover {
        background: rgba(59, 130, 246, 0.2);
        border-color: rgba(59, 130, 246, 0.3);
        color: #60a5fa;
    }

    .pagination .page-item.active .page-link {
        background: rgba(59, 130, 246, 0.3);
        border-color: #3b82f6;
        color: #ffffff;
    }

    .pagination .page-item.disabled .page-link {
        background: rgba(255, 255, 255, 0.02);
        border-color: rgba(255, 255, 255, 0.05);
        color: #475569;
        cursor: not-allowed;
    }

    .results-info {
        color: #94a3b8;
        font-size: 0.875rem;
    }
</style>

<!-- Breadcrumb Navigation -->
<nav class="breadcrumb-nav">
    <span class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></span>
    <span class="breadcrumb-divider">/</span>
    <span class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Admin</a></span>
    <span class="breadcrumb-divider">/</span>
    <span class="breadcrumb-item active">System Catalog</span>
</nav>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-folder2-open me-2"></i> System Catalog Management</h2>
        <div class="d-flex gap-2">
            <a href="@Url.Action("ExportJobsToCsv")" class="btn btn-outline-success btn-sm">
                <i class="bi bi-filetype-csv me-1"></i> Export Jobs
            </a>
            <a href="@Url.Action("ExportWaterSchedulesToCsv")" class="btn btn-outline-info btn-sm">
                <i class="bi bi-filetype-csv me-1"></i> Export Water
            </a>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="catalogTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active fw-bold" id="jobs-tab" data-bs-toggle="tab" data-bs-target="#jobs" type="button">💼 Jobs (@Model.Jobs.Count)</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold" id="water-tab" data-bs-toggle="tab" data-bs-target="#water" type="button">💧 Water (@Model.Water.Count)</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold" id="clinics-tab" data-bs-toggle="tab" data-bs-target="#clinics" type="button">🏥 Clinics (@Model.Clinics.Count)</button>
        </li>
    </ul>

    <div class="tab-content" id="catalogContent">
        <!-- JOBS TAB -->
        <div class="tab-pane fade show active" id="jobs">
            <div class="catalog-card">
                <table class="table hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Title / Company</th>
                            <th>Location</th>
                            <th>Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model.Jobs) {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-white">@job.Title</div>
                                    <div class="small text-muted">@job.Company</div>
                                    @if (!job.IsApproved) {
                                        <span class="badge bg-warning bg-opacity-25 text-warning small mt-1">Pending Approval</span>
                                    } else {
                                        <span class="badge bg-success bg-opacity-25 text-success small mt-1">Live on Site</span>
                                    }
                                </td>
                                <td>@job.Location</td>
                                <td>
                                    <form asp-action="UpdateJobComment" method="post" class="mt-1">
                                        <input type="hidden" name="id" value="@job.Id" />
                                        <div class="input-group input-group-sm">
                                            <input type="text" name="comment" class="form-control bg-dark border-secondary text-white" 
                                                   value="@job.AdminComment" placeholder="Private feedback..." />
                                            <button class="btn btn-outline-secondary" type="submit">Save</button>
                                        </div>
                                    </form>
                                </td>
                                <td class="text-end pe-4">
                                    @if (!job.IsApproved) {
                                        <form asp-action="ApproveJob" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@job.Id" />
                                            <button class="btn btn-sm btn-success fw-bold me-1">APPROVE</button>
                                        </form>
                                    }
                                    <form asp-action="DeleteJob" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@job.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Purge</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Jobs.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">💼</div>
                        <h4>No Job Postings</h4>
                        <p>No job postings are currently in the system.</p>
                        <a href="@Url.Action("Index", "Jobs")" class="btn btn-outline-primary">
                            <i class="bi bi-eye me-1"></i> View Public Job Board
                        </a>
                    </div>
                }
                
                <!-- Jobs Pagination -->
                @if (ViewBag.JobsTotalPages > 1)
                {
                    <div class="pagination-container">
                        <div class="results-info">Page @ViewBag.JobsCurrentPage of @ViewBag.JobsTotalPages (@ViewBag.JobsTotal total)</div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination">
                                <li class="page-item @(ViewBag.JobsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = 1, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.JobsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage - 1, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, ViewBag.JobsCurrentPage - 2); i <= Math.Min(ViewBag.JobsTotalPages, ViewBag.JobsCurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == ViewBag.JobsCurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = i, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.JobsCurrentPage == ViewBag.JobsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage + 1, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.JobsCurrentPage == ViewBag.JobsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsTotalPages, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
                else
                {
                    <div class="pagination-container">
                        <div class="results-info">Showing @Model.Jobs.Count of @ViewBag.JobsTotal jobs</div>
                    </div>
                }
            </div>
        </div>

        <!-- WATER TAB -->
        <div class="tab-pane fade" id="water">
            <div class="catalog-card">
                <table class="table hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Neighborhood</th>
                            <th>Status</th>
                            <th>Update Time</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var w in Model.Water) {
                            <tr>
                                <td class="ps-4 fw-bold text-white">@w.Location</td>
                                <td><span class="badge @(w.Status == "Active" ? "bg-success" : "bg-danger")">@w.Status</span></td>
                                <td class="small text-muted">@w.StartTime.ToString("HH:mm")</td>
                                <td class="text-end pe-4">
                                    <form asp-action="DeleteWater" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@w.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Water.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">💧</div>
                        <h4>No Water Schedules</h4>
                        <p>No water distribution schedules are currently recorded.</p>
                        <a href="@Url.Action("Index", "Water")" class="btn btn-outline-info">
                            <i class="bi bi-eye me-1"></i> View Public Water Page
                        </a>
                    </div>
                }
                
                <!-- Water Pagination -->
                @if (ViewBag.WaterTotalPages > 1)
                {
                    <div class="pagination-container">
                        <div class="results-info">Page @ViewBag.WaterCurrentPage of @ViewBag.WaterTotalPages (@ViewBag.WaterTotal total)</div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination">
                                <li class="page-item @(ViewBag.WaterCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = 1, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.WaterCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage - 1, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, ViewBag.WaterCurrentPage - 2); i <= Math.Min(ViewBag.WaterTotalPages, ViewBag.WaterCurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == ViewBag.WaterCurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = i, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.WaterCurrentPage == ViewBag.WaterTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage + 1, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.WaterCurrentPage == ViewBag.WaterTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterTotalPages, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
                else
                {
                    <div class="pagination-container">
                        <div class="results-info">Showing @Model.Water.Count of @ViewBag.WaterTotal water records</div>
                    </div>
                }
            </div>
        </div>

        <!-- CLINICS TAB -->
        <div class="tab-pane fade" id="clinics">
            <div class="catalog-card">
                <table class="table hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Clinic Name</th>
                            <th>Doctors</th>
                            <th>Medicine Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Clinics) {
                            <tr>
                                <td class="ps-4 fw-bold text-white">@c.ClinicName</td>
                                <td>@c.AvailableDoctors</td>
                                <td><span class="badge @(c.HasEssentialMedicines ? "bg-success" : "bg-warning")">@(c.HasEssentialMedicines ? "STOCK OK" : "LOW STOCK")</span></td>
                                <td class="text-end pe-4">
                                    <form asp-action="DeleteClinic" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button class="btn btn-sm btn-outline-danger">De-list</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Clinics.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🏥</div>
                        <h4>No Clinics Recorded</h4>
                        <p>No healthcare facilities are currently in the system.</p>
                        <a href="@Url.Action("Index", "Health")" class="btn btn-outline-success">
                            <i class="bi bi-eye me-1"></i> View Public Health Directory
                        </a>
                    </div>
                }
                
                <!-- Clinics Pagination -->
                @if (ViewBag.ClinicsTotalPages > 1)
                {
                    <div class="pagination-container">
                        <div class="results-info">Page @ViewBag.ClinicsCurrentPage of @ViewBag.ClinicsTotalPages (@ViewBag.ClinicsTotal total)</div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination">
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = 1, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage - 1, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, ViewBag.ClinicsCurrentPage - 2); i <= Math.Min(ViewBag.ClinicsTotalPages, ViewBag.ClinicsCurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == ViewBag.ClinicsCurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = i, pageSize = ViewBag.PageSize })#clinics">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == ViewBag.ClinicsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage + 1, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == ViewBag.ClinicsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsTotalPages, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
                else
                {
                    <div class="pagination-container">
                        <div class="results-info">Showing @Model.Clinics.Count of @ViewBag.ClinicsTotal clinics</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
