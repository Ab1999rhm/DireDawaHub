@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<DireDawaHub.SharedResource> localizer
@model DireDawaHub.ViewModels.CatalogViewModel
@{
    ViewData["Title"] = @localizer["System Catalog"];
}



<!-- Breadcrumb Navigation -->
<nav class="breadcrumb-nav">
    <span class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></span>
    <span class="breadcrumb-divider">/</span>
    <span class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Admin</a></span>
    <span class="breadcrumb-divider">/</span>
    <span class="breadcrumb-item active">@localizer["System Catalog"]</span>
</nav>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-white admin-header-anim"><i class="bi bi-folder2-open me-2"></i> @localizer["System Catalog Management"]</h2>
        <div class="dropdown admin-header-anim" style="animation-delay: 0.1s;">
            <button class="admin-btn admin-btn-outline dropdown-toggle" type="button" id="exportDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-download me-1"></i> @localizer["Export Data"]
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="exportDropdown">
                <li><h6 class="dropdown-header">@localizer["Catalog Data"]</h6></li>
                <li><a class="dropdown-item" href="@Url.Action("ExportJobsToCsv")"><i class="bi bi-briefcase me-2"></i>@localizer["All Jobs"]</a></li>
                <li><a class="dropdown-item" href="@Url.Action("ExportWaterSchedulesToCsv")"><i class="bi bi-droplet me-2"></i>@localizer["Water Schedules"]</a></li>
                <li><a class="dropdown-item" href="@Url.Action("ExportClinicsToCsv")"><i class="bi bi-hospital me-2"></i>@localizer["Clinic Records"]</a></li>
                @if (Model.Jobs.Any())
                {
                    <li><hr class="dropdown-divider"></li>
                    <li><h6 class="dropdown-header">@localizer["Export by Job Title"]</h6></li>
                    @foreach (var jobTitle in Model.Jobs.Select(j => j.Title).Distinct().Take(10))
                    {
                        <li><a class="dropdown-item" href="@Url.Action("ExportJobsByTitle", new { title = jobTitle })"><i class="bi bi-filter me-2"></i>@jobTitle</a></li>
                    }
                }
            </ul>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="catalogTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active fw-bold" id="jobs-tab" data-bs-toggle="tab" data-bs-target="#jobs" type="button">💼 @localizer["Jobs"] (@Model.Jobs.Count)</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold" id="water-tab" data-bs-toggle="tab" data-bs-target="#water" type="button">💧 @localizer["Water"] (@Model.Water.Count)</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold" id="clinics-tab" data-bs-toggle="tab" data-bs-target="#clinics" type="button">🏥 @localizer["Clinics"] (@Model.Clinics.Count)</button>
        </li>
    </ul>

    <div class="tab-content admin-header-anim" id="catalogContent" style="animation-delay: 0.2s;">
        <!-- JOBS TAB -->
        <div class="tab-pane fade show active" id="jobs">
            <div class="admin-table-wrapper mb-4">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th class="ps-4">@localizer["Title / Company"]</th>
                            <th>@localizer["Location"]</th>
                            <th>@localizer["Date"]</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model.Jobs) {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-white">@job.Title</div>
                                    <div class="small text-muted">@job.Company</div>
                                    @if (!job.IsApproved) {
                                        <span class="badge bg-warning bg-opacity-25 text-warning small mt-1">@localizer["Pending Approval"]</span>
                                    } else {
                                        <span class="badge bg-success bg-opacity-25 text-success small mt-1">@localizer["Live on Site"]</span>
                                    }
                                </td>
                                <td>@job.Location</td>
                                <td>
                                    <form asp-action="UpdateJobComment" method="post" class="mt-1">
                                        <input type="hidden" name="id" value="@job.Id" />
                                        <div class="input-group input-group-sm">
                                            <input type="text" name="comment" class="form-control bg-dark border-secondary text-white" 
                                                   value="@job.AdminComment" placeholder="@localizer["Private feedback..."]" />
                                            <button class="btn btn-outline-secondary" type="submit">@localizer["Save"]</button>
                                        </div>
                                    </form>
                                </td>
                                <td class="text-end pe-4">
                                    @if (!job.IsApproved) {
                                        <form asp-action="ApproveJob" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@job.Id" />
                                            <button class="admin-btn admin-btn-primary btn-sm me-1" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">@localizer["APPROVE"]</button>
                                        </form>
                                    }
                                    <form asp-action="DeleteJob" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@job.Id" />
                                        <button class="admin-btn admin-btn-outline btn-sm text-danger border-danger border-opacity-25">@localizer["Purge"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Jobs.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">💼</div>
                        <h4>@localizer["No Job Postings"]</h4>
                        <p>@localizer["No job postings are currently in the system."]</p>
                        <a href="@Url.Action("Index", "Jobs")" class="btn btn-outline-primary">
                            <i class="bi bi-eye me-1"></i> @localizer["View Public Job Board"]
                        </a>
                    </div>
                }
                
                <!-- Jobs Pagination -->
                @if (ViewBag.JobsTotalPages > 1)
                {
                    <div class="admin-pagination-container">
                        <div class="results-info">@localizer["Page"] @ViewBag.JobsCurrentPage @localizer["of"] @ViewBag.JobsTotalPages (@ViewBag.JobsTotal @localizer["total"])</div>
                        <nav aria-label="Page navigation">
                            <ul class="admin-pagination list-unstyled d-flex mb-0">
                                <li class="page-item @(ViewBag.JobsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = 1, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.JobsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage - 1, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, ViewBag.JobsCurrentPage - 2); i <= Math.Min(ViewBag.JobsTotalPages, ViewBag.JobsCurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == ViewBag.JobsCurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = i, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.JobsCurrentPage == ViewBag.JobsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage + 1, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.JobsCurrentPage == ViewBag.JobsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsTotalPages, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#jobs">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
                else
                {
                    <div class="admin-pagination-container">
                        <div class="results-info">@localizer["Showing"] @Model.Jobs.Count @localizer["of"] @ViewBag.JobsTotal @localizer["jobs"]</div>
                    </div>
                }
            </div>
        </div>

        <!-- WATER TAB -->
        <div class="tab-pane fade" id="water">
            <div class="admin-table-wrapper mb-4">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th class="ps-4">@localizer["Neighborhood"]</th>
                            <th>@localizer["Status"]</th>
                            <th>@localizer["Update Time"]</th>
                            <th class="text-end pe-4">@localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var w in Model.Water) {
                            <tr>
                                <td class="ps-4 fw-bold text-white">@w.Location</td>
                                <td><span class="badge @(w.Status == "Active" ? "bg-success" : "bg-danger")">@w.Status</span></td>
                                <td class="small text-muted">@w.StartTime.ToString("HH:mm")</td>
                                <td class="text-end pe-4">
                                    <form asp-action="DeleteWater" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@w.Id" />
                                        <button class="admin-btn admin-btn-outline btn-sm text-danger border-danger border-opacity-25">@localizer["Remove"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Water.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">💧</div>
                        <h4>@localizer["No Water Schedules"]</h4>
                        <p>@localizer["No water distribution schedules are currently recorded."]</p>
                        <a href="@Url.Action("Index", "Water")" class="btn btn-outline-info">
                            <i class="bi bi-eye me-1"></i> @localizer["View Public Water Page"]
                        </a>
                    </div>
                }
                
                <!-- Water Pagination -->
                @if (ViewBag.WaterTotalPages > 1)
                {
                    <div class="admin-pagination-container">
                        <div class="results-info">@localizer["Page"] @ViewBag.WaterCurrentPage @localizer["of"] @ViewBag.WaterTotalPages (@ViewBag.WaterTotal @localizer["total"])</div>
                        <nav aria-label="Page navigation">
                            <ul class="admin-pagination list-unstyled d-flex mb-0">
                                <li class="page-item @(ViewBag.WaterCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = 1, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.WaterCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage - 1, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, ViewBag.WaterCurrentPage - 2); i <= Math.Min(ViewBag.WaterTotalPages, ViewBag.WaterCurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == ViewBag.WaterCurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = i, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.WaterCurrentPage == ViewBag.WaterTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage + 1, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.WaterCurrentPage == ViewBag.WaterTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterTotalPages, clinicsPage = ViewBag.ClinicsCurrentPage, pageSize = ViewBag.PageSize })#water">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
                else
                {
                    <div class="admin-pagination-container">
                        <div class="results-info">@localizer["Showing"] @Model.Water.Count @localizer["of"] @ViewBag.WaterTotal @localizer["water"]</div>
                    </div>
                }
            </div>
        </div>

        <!-- CLINICS TAB -->
        <div class="tab-pane fade" id="clinics">
            <div class="admin-table-wrapper mb-4">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th class="ps-4">@localizer["Clinic Name"]</th>
                            <th>@localizer["Doctors"]</th>
                            <th>@localizer["Medicine Status"]</th>
                            <th class="text-end pe-4">@localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Clinics) {
                            <tr>
                                <td class="ps-4 fw-bold text-white">@c.ClinicName</td>
                                <td>@c.AvailableDoctors</td>
                                <td><span class="badge @(c.HasEssentialMedicines ? "bg-success" : "bg-warning")">@(c.HasEssentialMedicines ? @localizer["STOCK OK"] : @localizer["LOW STOCK"])</span></td>
                                <td class="text-end pe-4">
                                    <form asp-action="DeleteClinic" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button class="admin-btn admin-btn-outline btn-sm text-danger border-danger border-opacity-25">@localizer["De-list"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Clinics.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🏥</div>
                        <h4>@localizer["No Clinics Recorded"]</h4>
                        <p>@localizer["No healthcare facilities are currently in the system."]</p>
                        <a href="@Url.Action("Index", "Health")" class="btn btn-outline-success">
                            <i class="bi bi-eye me-1"></i> @localizer["View Public Health Directory"]
                        </a>
                    </div>
                }
                
                <!-- Clinics Pagination -->
                @if (ViewBag.ClinicsTotalPages > 1)
                {
                    <div class="admin-pagination-container">
                        <div class="results-info">@localizer["Page"] @ViewBag.ClinicsCurrentPage @localizer["of"] @ViewBag.ClinicsTotalPages (@ViewBag.ClinicsTotal @localizer["total"])</div>
                        <nav aria-label="Page navigation">
                            <ul class="admin-pagination list-unstyled d-flex mb-0">
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = 1, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage - 1, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, ViewBag.ClinicsCurrentPage - 2); i <= Math.Min(ViewBag.ClinicsTotalPages, ViewBag.ClinicsCurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == ViewBag.ClinicsCurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = i, pageSize = ViewBag.PageSize })#clinics">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == ViewBag.ClinicsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsCurrentPage + 1, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item @(ViewBag.ClinicsCurrentPage == ViewBag.ClinicsTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Catalog", new { jobsPage = ViewBag.JobsCurrentPage, waterPage = ViewBag.WaterCurrentPage, clinicsPage = ViewBag.ClinicsTotalPages, pageSize = ViewBag.PageSize })#clinics">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
                else
                {
                    <div class="admin-pagination-container">
                        <div class="results-info">@localizer["Showing"] @Model.Clinics.Count @localizer["of"] @ViewBag.ClinicsTotal @localizer["clinics"]</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
