@model DireDawaHub.Models.WaterSchedule
@{
    ViewData["Title"] = "Edit Water Schedule";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4">💧 Edit Water Schedule</h2>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-bold">Location</label>
                            <input asp-for="Location" class="form-control rounded-3" required />
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-6">
                                <label asp-for="StartTime" class="form-label fw-bold">Start Time</label>
                                <input asp-for="StartTime" class="form-control rounded-3" required />
                            </div>
                            <div class="col-6">
                                <label asp-for="EndTime" class="form-label fw-bold">End Time</label>
                                <input asp-for="EndTime" class="form-control rounded-3" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-bold">Status</label>
                            <select asp-for="Status" class="form-select rounded-3">
                                <option value="Active">Active</option>
                                <option value="Delayed">Delayed</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Stable">Stable</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-bold">Notes</label>
                            <textarea asp-for="Notes" class="form-control rounded-3" rows="3"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-3 fw-bold">SAVE CHANGES</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill py-3">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
