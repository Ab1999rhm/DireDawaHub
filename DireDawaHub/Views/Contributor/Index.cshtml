@{
    ViewData["Title"] = "Contributor Portal";
}

<div class="mb-5 mt-2">
    <h2 class="fw-bold mb-2" style="color: #111827;">👩‍💻 Welcome to your Dashboard</h2>
    <p class="text-muted">Direct portal for submitting official municipal updates to the community notice board.</p>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-3">
        <a asp-controller="Water" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #3b82f6 !important; transition: 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4 text-center">
                    <div class="bg-primary bg-opacity-10 d-inline-block p-3 rounded-circle text-primary fs-2 mb-3">💧</div>
                    <h5 class="fw-bold text-dark mb-1">Water Tracker</h5>
                    <p class="small text-muted mb-0">Update pipe status and broadcast live SignalR delays.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Health" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #f43f5e !important; transition: 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4 text-center">
                    <div class="bg-danger bg-opacity-10 d-inline-block p-3 rounded-circle text-danger fs-2 mb-3">🏥</div>
                    <h5 class="fw-bold text-dark mb-1">Health Clinics</h5>
                    <p class="small text-muted mb-0">Modify hospital capacities and medicine stocks.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Jobs" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #8b5cf6 !important; transition: 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4 text-center">
                    <div class="bg-info bg-opacity-10 d-inline-block p-3 rounded-circle text-info fs-2 mb-3">💼</div>
                    <h5 class="fw-bold text-dark mb-1">Job Postings</h5>
                    <p class="small text-muted mb-0">List new public or private employment opportunities.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Agriculture" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #10b981 !important; transition: 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4 text-center">
                    <div class="bg-success bg-opacity-10 d-inline-block p-3 rounded-circle text-success fs-2 mb-3">🌾</div>
                    <h5 class="fw-bold text-dark mb-1">Agriculture Base</h5>
                    <p class="small text-muted mb-0">Approve automated market prices and report diseases.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a asp-controller="Contributor" asp-action="MyPosters" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #f59e0b !important; transition: 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4 text-center">
                    <div class="bg-warning bg-opacity-10 d-inline-block p-3 rounded-circle text-warning fs-2 mb-3">🖼️</div>
                    <h5 class="fw-bold text-dark mb-1">Community Posters</h5>
                    <p class="small text-muted mb-0">Upload high-quality event posters and announcements.</p>
                </div>
            </div>
        </a>
    </div>
</div>
