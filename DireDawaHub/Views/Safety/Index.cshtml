@model IEnumerable<DireDawaHub.Models.PublicSafetyIncident>
@{
    ViewData["Title"] = "Public Safety Alerts";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🚔 Public Safety Alerts</h2>
        @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Contributor")))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4">Report Incident</a>
        }
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle text-white">
                <thead>
                    <tr class="opacity-50 small text-uppercase">
                        <th>Incident</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Location</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.Title</div>
                                <div class="small opacity-75">@item.Description</div>
                            </td>
                            <td><span class="badge bg-secondary">@item.IncidentType</span></td>
                            <td>
                                <span class="badge @(item.Status == "Active" ? "bg-danger" : "bg-success")">
                                    @item.Status
                                </span>
                            </td>
                            <td>@item.Location</td>
                            <td>@item.ReportedAt.ToString("MMM dd, HH:mm")</td>
                            <td>
                                @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Contributor")))
                                {
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Edit</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this report?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
