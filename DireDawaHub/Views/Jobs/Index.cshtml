@model IEnumerable<DireDawaHub.Models.JobPosting>
@{
    ViewData["Title"] = "Job Board";
}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>💼 Job & Training Board</h2>
        @if (User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Contributor")))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold px-4" style="border-radius: 8px; transition: 0.2s;">+ Post Opportunity</a>
        }
    </div>

<div class="row">
    @foreach (var item in Model) {
        <div class="col-12 mb-4">
            <div class="card shadow-sm border-0 d-flex flex-row overflow-hidden" style="border-radius: 12px; transition: transform 0.2s; min-height: 140px;">
                <div class="@(item.IsTrainingOpportunity ? "bg-warning" : "bg-primary")" style="width: 8px;"></div>
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        @if(item.IsTrainingOpportunity){
                            <span class="badge bg-warning text-dark rounded-pill px-3 py-1 fw-bold mb-2 shadow-sm">Training / Apprenticeship</span>
                        } else {
                            <span class="badge bg-primary rounded-pill px-3 py-1 fw-bold mb-2 shadow-sm">Full-Time Job</span>
                        }
                        
                        <h4 class="fw-bold mb-1 text-dark">@item.Title</h4>
                        <p class="text-muted mb-0 fs-5">
                            <i class="bi bi-building"></i> @item.Company &nbsp;|&nbsp; 
                            <i class="bi bi-geo-alt"></i> @item.Location
                        </p>
                        <p class="text-secondary mt-3 mb-0" style="max-width: 700px;">@item.Description</p>
                    </div>
                    <div class="text-end" style="min-width: 180px;">
                        <span class="d-block text-muted small mb-3">Posted @item.PostedDate.ToString("MMM dd, yyyy")</span>
                        <button class="btn btn-primary fw-bold px-4" style="border-radius: 8px;">Apply Now</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if(!Model.Any()) {
        <div class="col-12 text-center text-muted mt-5 py-5 bg-white rounded-3 shadow-sm">
            <div style="font-size: 3rem; margin-bottom: 20px;">🗞️</div>
            <h4>No local jobs or trainings posted.</h4>
            <p>Employers can post listings through the contributor portal.</p>
        </div>
    }
</div>
