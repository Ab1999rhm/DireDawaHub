@model DireDawaHub.Models.ClinicRecord
@{
    ViewData["Title"] = "Update Clinic Record";
}

<div class="card shadow-sm border-0" style="border-radius: 12px; max-width: 650px; margin: 0 auto; margin-top: 20px;">
    <div class="card-body p-5">
        <h3 class="mb-4 fw-bold" style="color: #111827;">Update Clinic Status</h3>
        <p class="text-muted mb-4">Provide live updates on doctor availability and essential medicine stocks.</p>
        
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-4">
                <label asp-for="ClinicName" class="form-label fw-bold text-muted small text-uppercase">Clinic / Hospital Name</label>
                <input asp-for="ClinicName" class="form-control" style="padding: 12px; border-radius: 8px;" placeholder="e.g. Sabian General Hospital" required />
            </div>

            <div class="mb-4">
                <label asp-for="AvailableDoctors" class="form-label fw-bold text-muted small text-uppercase">Doctors Available</label>
                <input asp-for="AvailableDoctors" class="form-control" style="padding: 12px; border-radius: 8px;" placeholder="e.g. Dr. Abebe (Pediatrics), Dr. Sara (General)" required />
            </div>

            <div class="mb-4 p-4 border rounded-3 bg-light">
                <div class="form-check form-switch d-flex align-items-center gap-3 m-0">
                    <input class="form-check-input" type="checkbox" asp-for="HasEssentialMedicines" style="width: 3em; height: 1.5em; cursor: pointer;">
                    <label class="form-check-label fw-bold fs-5" asp-for="HasEssentialMedicines" style="cursor: pointer;">
                        Essential Medicines are fully stocked
                    </label>
                </div>
            </div>

            <div class="mb-5">
                <label asp-for="EmergencyContact" class="form-label fw-bold text-muted small text-uppercase">Emergency Phone Number</label>
                <input asp-for="EmergencyContact" class="form-control" style="padding: 12px; border-radius: 8px;" placeholder="e.g. 025-111-2233" required />
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="text-muted text-decoration-none fw-bold">← Cancel</a>
                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold" style="border-radius: 8px; font-size: 1.1rem;">Post Live Update</button>
            </div>
        </form>
    </div>
</div>
